{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/package_sync_v0.schema.json",
  "title": "WhippleScript Package Sync v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "package_set_path",
    "package_lock_path",
    "packages",
    "package_lock_digest",
    "diagnostics"
  ],
  "properties": {
    "schema": {
      "const": "whipplescript.package_sync.v0"
    },
    "status": {
      "enum": ["ok", "error"]
    },
    "package_set_path": {
      "type": "string",
      "minLength": 1
    },
    "package_lock_path": {
      "type": "string",
      "minLength": 1
    },
    "packages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "package_id",
          "name",
          "version",
          "source",
          "manifest_sha256"
        ],
        "properties": {
          "package_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "$ref": "#/$defs/source"
          },
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "package_lock_digest": {
      "$ref": "#/$defs/digest"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "path"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/)|(^[A-Za-z]:)|(^|/)\\.\\.(/|$)"
          }
        }
      }
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
