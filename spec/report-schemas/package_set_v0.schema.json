{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/package_set_v0.schema.json",
  "title": "WhippleScript Package Set v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "packages"],
  "properties": {
    "schema": {
      "const": "whipplescript.package_set.v0"
    },
    "packages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/package"
      }
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "package_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "path"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/)|(^[A-Za-z]:)|(^|/)\\.\\.(/|$)"
          }
        }
      }
    }
  }
}
