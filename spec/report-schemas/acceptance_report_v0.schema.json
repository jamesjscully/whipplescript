{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.local/schemas/acceptance_report_v0.schema.json",
  "title": "WhippleScript acceptance report v0",
  "type": "object",
  "required": ["schema", "fixture", "workflow", "passed", "failures", "observed", "dev_report"],
  "properties": {
    "schema": {"const": "whipplescript.acceptance_report.v0"},
    "fixture": {"type": "string"},
    "workflow": {"type": "string"},
    "passed": {"type": "boolean"},
    "failures": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed": {
      "type": "object",
      "required": ["summary", "facts", "effects"],
      "properties": {
        "summary": {
          "type": "object",
          "required": ["facts", "effects"],
          "properties": {
            "facts": {"type": "integer", "minimum": 0},
            "effects": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        },
        "facts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "count"],
            "properties": {
              "name": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "status", "count"],
            "properties": {
              "kind": {"type": "string"},
              "status": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "event_id", "sequence"],
            "properties": {
              "type": {"enum": ["pause", "resume", "cancel"]},
              "event_id": {"type": "string"},
              "sequence": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "source_metadata": {
          "type": "object",
          "required": ["summary", "targets"],
          "properties": {
            "summary": {
              "type": "object",
              "required": ["targets"],
              "properties": {
                "targets": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "targets": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "target_kind", "target", "tags", "description"],
                "properties": {
                  "key": {"type": "string"},
                  "target_kind": {"type": "string"},
                  "target": {"type": "string"},
                  "tags": {
                    "type": "array",
                    "items": {"type": "string"}
                  },
                  "description": {"type": ["string", "null"]}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "runs": {
          "type": "object",
          "required": ["summary", "groups"],
          "properties": {
            "summary": {
              "type": "object",
              "required": ["total", "artifact_count"],
              "properties": {
                "total": {"type": "integer", "minimum": 0},
                "artifact_count": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["provider", "status", "count", "artifact_count"],
                "properties": {
                  "provider": {"type": "string"},
                  "status": {"type": "string"},
                  "count": {"type": "integer", "minimum": 0},
                  "artifact_count": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "artifacts": {
          "type": "object",
          "required": ["summary", "groups"],
          "properties": {
            "summary": {
              "type": "object",
              "required": ["total"],
              "properties": {
                "total": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "mime_type", "count"],
                "properties": {
                  "kind": {"type": "string"},
                  "mime_type": {"type": ["string", "null"]},
                  "count": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": true
              }
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["artifact_id", "run_id", "kind", "mime_type"],
                "properties": {
                  "artifact_id": {"type": "string"},
                  "run_id": {"type": "string"},
                  "kind": {"type": "string"},
                  "mime_type": {"type": ["string", "null"]},
                  "content_hash": {"type": ["string", "null"]}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "evidence": {
          "type": "object",
          "required": ["summary", "groups"],
          "properties": {
            "summary": {
              "type": "object",
              "required": ["total"],
              "properties": {
                "total": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "subject_type", "count"],
                "properties": {
                  "kind": {"type": "string"},
                  "subject_type": {"type": "string"},
                  "count": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": true
              }
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["evidence_id", "kind", "subject_type", "subject_id"],
                "properties": {
                  "evidence_id": {"type": "string"},
                  "kind": {"type": "string"},
                  "subject_type": {"type": "string"},
                  "subject_id": {"type": "string"},
                  "causation_id": {"type": ["string", "null"]},
                  "correlation_id": {"type": ["string", "null"]},
                  "summary": {"type": ["string", "null"]}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "inbox": {
          "type": "object",
          "required": ["summary", "groups"],
          "properties": {
            "summary": {
              "type": "object",
              "required": ["total"],
              "properties": {
                "total": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["status", "severity", "count"],
                "properties": {
                  "status": {"type": "string"},
                  "severity": {"type": "string"},
                  "count": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "trace": {
          "type": "object",
          "required": ["summary", "groups", "items", "conformance"],
          "properties": {
            "summary": {
              "type": "object",
              "required": ["events", "abstract_events"],
              "properties": {
                "events": {"type": "integer", "minimum": 0},
                "abstract_events": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "count"],
                "properties": {
                  "type": {"type": "string"},
                  "count": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": true
              }
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["sequence", "event"],
                "properties": {
                  "sequence": {"type": "integer", "minimum": 0},
                  "event": {
                    "type": "object",
                    "required": ["type"],
                    "properties": {
                      "type": {"type": "string"}
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            },
            "conformance": {
              "type": "object",
              "required": ["ok"],
              "properties": {
                "ok": {"type": "boolean"},
                "sequence": {"type": "integer", "minimum": 0},
                "message": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "diagnostics_by_code": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "count"],
            "properties": {
              "code": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "assertion_reads": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "head", "source", "match_count", "matches"],
            "properties": {
              "kind": {"enum": ["fact", "effect"]},
              "head": {"type": "string"},
              "guard": {"type": "string"},
              "source": {"type": "string"},
              "match_count": {"type": "integer", "minimum": 0},
              "matches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "status", "prompt_content_type", "provenance_class", "count"],
                  "properties": {
                    "name": {"type": ["string", "null"]},
                    "status": {"type": ["string", "null"]},
                    "prompt_content_type": {"type": ["string", "null"]},
                    "provenance_class": {"type": ["string", "null"]},
                    "trace_items": {"type": "integer", "minimum": 0},
                    "evidence_items": {"type": "integer", "minimum": 0},
                    "trace_sequences": {
                      "type": "array",
                      "items": {"type": "integer", "minimum": 0}
                    },
                    "evidence_ids": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "count": {"type": "integer", "minimum": 0}
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        },
        "executable_spec": {
          "type": "object",
          "required": ["status", "summary", "tags"],
          "properties": {
            "status": {"enum": ["passed", "failed", "error"]},
            "summary": {
              "type": "object",
              "properties": {
                "total": {"type": "integer", "minimum": 0},
                "passed": {"type": "integer", "minimum": 0},
                "failed": {"type": "integer", "minimum": 0},
                "error": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["tag", "status", "summary"],
                "properties": {
                  "tag": {"type": "string"},
                  "status": {"enum": ["passed", "failed", "error"]},
                  "summary": {
                    "type": "object",
                    "properties": {
                      "total": {"type": "integer", "minimum": 0},
                      "passed": {"type": "integer", "minimum": 0},
                      "failed": {"type": "integer", "minimum": 0},
                      "error": {"type": "integer", "minimum": 0}
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            },
            "untagged": {
              "type": "object",
              "required": ["status", "summary"],
              "properties": {
                "status": {"enum": ["passed", "failed", "error"]},
                "summary": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "minimum": 0},
                    "passed": {"type": "integer", "minimum": 0},
                    "failed": {"type": "integer", "minimum": 0},
                    "error": {"type": "integer", "minimum": 0}
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "dev_report": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": {"const": "whipplescript.dev_report.v0"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
