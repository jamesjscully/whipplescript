{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/platform_construct_catalog_v0.schema.json",
  "title": "WhippleScript Platform Construct Catalog v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "families",
    "lowerings",
    "scopes",
    "field_kinds",
    "interface_kinds",
    "interface_phases",
    "interface_cardinalities",
    "reserved_keywords",
    "reserved_keyword_privileges"
  ],
  "properties": {
    "schema": {
      "const": "whipplescript.platform_construct_catalog.v0"
    },
    "families": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/platform_construct_family"
      }
    },
    "lowerings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/platform_construct_lowering"
      }
    },
    "scopes": {
      "$ref": "#/$defs/string_array"
    },
    "field_kinds": {
      "$ref": "#/$defs/string_array"
    },
    "interface_kinds": {
      "$ref": "#/$defs/string_array"
    },
    "interface_phases": {
      "$ref": "#/$defs/string_array"
    },
    "interface_cardinalities": {
      "$ref": "#/$defs/string_array"
    },
    "reserved_keywords": {
      "$ref": "#/$defs/string_array"
    },
    "reserved_keyword_privileges": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/reserved_keyword_privilege"
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "platform_construct_family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform_construct_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "compatible_families",
        "package_authorable",
        "required_scope",
        "target_capability",
        "required_interfaces",
        "provided_interfaces",
        "lifecycle_profiles",
        "authority_profile",
        "static_guarantees"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "compatible_families": {
          "$ref": "#/$defs/string_array"
        },
        "package_authorable": {
          "type": "boolean"
        },
        "required_scope": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "target_capability": {
          "enum": ["forbidden", "required_capability_call_contract"]
        },
        "required_interfaces": {
          "$ref": "#/$defs/string_array"
        },
        "provided_interfaces": {
          "$ref": "#/$defs/string_array"
        },
        "lifecycle_profiles": {
          "$ref": "#/$defs/string_array"
        },
        "authority_profile": {
          "enum": [
            "none",
            "capability_scoped",
            "event_admission",
            "projection_source"
          ]
        },
        "static_guarantees": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "deterministic",
              "contract_pinned",
              "no_runtime_inputs",
              "no_hidden_authority",
              "no_package_scheduler",
              "no_package_lifecycle",
              "no_direct_fact_write",
              "no_direct_rule_fire"
            ]
          }
        }
      }
    },
    "reserved_keyword_privilege": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyword",
        "library_id",
        "construct_family",
        "scope",
        "lowering_target"
      ],
      "properties": {
        "keyword": {
          "type": "string",
          "minLength": 1
        },
        "library_id": {
          "type": "string",
          "minLength": 1
        },
        "construct_family": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "lowering_target": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
