{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.local/schemas/acceptance_fixture_v0.schema.json",
  "title": "WhippleScript acceptance fixture v0",
  "type": "object",
  "required": ["schema", "workflow", "expect"],
  "properties": {
    "schema": {"const": "whipplescript.acceptance_fixture.v0"},
    "workflow": {"type": "string"},
    "root": {"type": "string"},
    "provider": {"type": "string"},
    "provider_config_paths": {
      "type": "array",
      "items": {"type": "string"}
    },
    "input": {},
    "setup": {
      "type": "object",
      "properties": {
        "facts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": {"type": "string"},
              "key": {"type": "string"},
              "value": {}
            },
            "additionalProperties": true
          }
        },
        "inbox": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["prompt"],
            "properties": {
              "inbox_item_id": {"type": "string"},
              "effect_id": {"type": "string"},
              "status": {"type": "string"},
              "prompt": {"type": "string"},
              "choices": {"type": "array"},
              "freeform_allowed": {"type": "boolean"},
              "severity": {"type": "string"},
              "related_effects": {"type": "array"},
              "related_artifacts": {"type": "array"}
            },
            "additionalProperties": true
          }
        },
        "effects": false,
        "artifacts": false
      },
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"enum": ["pause", "resume", "cancel"]},
          "reason": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "include_tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "exclude_tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "outcome": {
      "enum": ["completed", "failed", "timed_out", "timeout", "cancelled", "cancel"]
    },
    "max_iterations": {"type": "integer", "minimum": 1},
    "expect": {
      "type": "object",
      "properties": {
        "dev_status": {"enum": ["success", "failure"]},
        "workflow": {"type": "string"},
        "status": {"enum": ["passed", "failed", "error"]},
        "source_metadata": {
          "type": "object",
          "properties": {
            "targets": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["target_kind", "target"],
                "properties": {
                  "target_kind": {"type": "string"},
                  "target": {"type": "string"},
                  "tags": {
                    "type": "array",
                    "items": {"type": "string"}
                  },
                  "description": {"type": "string"}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "diagnostics": {"type": "integer", "minimum": 0},
        "diagnostics_by_code": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "count"],
            "properties": {
              "code": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "count"],
            "properties": {
              "type": {"enum": ["pause", "resume", "cancel"]},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "assertion_reads": {
          "type": "array",
          "items": {
            "type": "object",
            "anyOf": [
              {"required": ["source"]},
              {"required": ["kind"]},
              {"required": ["head"]},
              {"required": ["guard"]}
            ],
            "properties": {
              "source": {"type": "string"},
              "kind": {"enum": ["fact", "effect"]},
              "head": {"type": "string"},
              "guard": {"type": "string"},
              "match_count": {"type": "integer", "minimum": 0},
              "matches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["count"],
                  "properties": {
                    "name": {"type": "string"},
                    "status": {"type": "string"},
                    "prompt_content_type": {"type": "string"},
                    "provenance_class": {"type": "string"},
                    "trace_items": {"type": "integer", "minimum": 0},
                    "evidence_items": {"type": "integer", "minimum": 0},
                    "trace_sequences": {
                      "type": "array",
                      "items": {"type": "integer", "minimum": 0}
                    },
                    "evidence_ids": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "count": {"type": "integer", "minimum": 0}
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        },
        "trace": {
          "type": "object",
          "properties": {
            "summary": {
              "type": "object",
              "properties": {
                "events": {"type": "integer", "minimum": 0},
                "abstract_events": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "count"],
                "properties": {
                  "type": {"type": "string"},
                  "count": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": true
              }
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "anyOf": [
                  {"required": ["sequence"]},
                  {"required": ["type"]},
                  {"required": ["effect_id"]},
                  {"required": ["run_id"]},
                  {"required": ["status"]},
                  {"required": ["predicate"]},
                  {"required": ["reason"]},
                  {"required": ["provider"]}
                ],
                "properties": {
                  "sequence": {"type": "integer", "minimum": 0},
                  "type": {"type": "string"},
                  "effect_id": {"type": "string"},
                  "run_id": {"type": "string"},
                  "status": {"type": "string"},
                  "predicate": {"type": "string"},
                  "reason": {"type": "string"},
                  "provider": {"type": "string"}
                },
                "additionalProperties": true
              }
            },
            "conformance": {
              "type": "object",
              "properties": {
                "ok": {"type": "boolean"}
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "inbox": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["status", "count"],
            "properties": {
              "status": {"type": "string"},
              "severity": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "assertions": {
          "type": "object",
          "properties": {
            "total": {"type": "integer", "minimum": 0},
            "passed": {"type": "integer", "minimum": 0},
            "failed": {"type": "integer", "minimum": 0},
            "error": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        },
        "assertion_tags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tag"],
            "properties": {
              "tag": {"type": "string"},
              "total": {"type": "integer", "minimum": 0},
              "passed": {"type": "integer", "minimum": 0},
              "failed": {"type": "integer", "minimum": 0},
              "error": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "assertion_untagged": {
          "type": "object",
          "properties": {
            "total": {"type": "integer", "minimum": 0},
            "passed": {"type": "integer", "minimum": 0},
            "failed": {"type": "integer", "minimum": 0},
            "error": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        },
        "summary": {
          "type": "object",
          "properties": {
            "facts": {"type": "integer", "minimum": 0},
            "effects": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        },
        "facts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "count"],
            "properties": {
              "name": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "count"],
            "properties": {
              "kind": {"type": "string"},
              "status": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "runs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["provider", "count"],
            "properties": {
              "provider": {"type": "string"},
              "status": {"type": "string"},
              "count": {"type": "integer", "minimum": 0},
              "artifact_count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "count"],
            "properties": {
              "kind": {"type": "string"},
              "mime_type": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "count"],
            "properties": {
              "kind": {"type": "string"},
              "subject_type": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
