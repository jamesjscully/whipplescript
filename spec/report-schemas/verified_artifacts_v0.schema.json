{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/verified_artifacts_v0.schema.json",
  "title": "WhippleScript verified artifact bundle v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "emit", "entries"],
  "properties": {
    "schema": {"const": "whipplescript.verified_artifacts.v0"},
    "status": {"const": "ok"},
    "emit": {
      "type": "string",
      "enum": ["construct-graph", "lowered-ir", "artifacts"]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"emit": {"const": "construct-graph"}},
        "required": ["emit"]
      },
      "then": {
        "properties": {
          "entries": {
            "items": {
              "required": ["construct_graph"],
              "not": {"required": ["lowered_ir_report"]}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"emit": {"const": "lowered-ir"}},
        "required": ["emit"]
      },
      "then": {
        "properties": {
          "entries": {
            "items": {
              "required": ["construct_graph", "lowered_ir_report"]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"emit": {"const": "artifacts"}},
        "required": ["emit"]
      },
      "then": {
        "properties": {
          "entries": {
            "items": {
              "required": ["construct_graph", "lowered_ir_report"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "stable_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "id": {"type": "string", "minLength": 1},
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "platform_construct_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "families",
        "lowerings",
        "scopes",
        "field_kinds",
        "interface_kinds",
        "interface_phases",
        "interface_cardinalities",
        "reserved_keywords",
        "reserved_keyword_privileges"
      ],
      "properties": {
        "schema": {"const": "whipplescript.platform_construct_catalog.v0"},
        "families": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/platform_construct_family"}
        },
        "lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/platform_construct_lowering"}
        },
        "scopes": {"$ref": "#/$defs/string_array"},
        "field_kinds": {"$ref": "#/$defs/string_array"},
        "interface_kinds": {"$ref": "#/$defs/string_array"},
        "interface_phases": {"$ref": "#/$defs/string_array"},
        "interface_cardinalities": {"$ref": "#/$defs/string_array"},
        "reserved_keywords": {"$ref": "#/$defs/string_array"},
        "reserved_keyword_privileges": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/reserved_keyword_privilege"}
        }
      }
    },
    "platform_construct_family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "platform_construct_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "compatible_families",
        "package_authorable",
        "required_scope",
        "target_capability",
        "required_interfaces",
        "provided_interfaces",
        "lifecycle_profiles",
        "authority_profile",
        "static_guarantees"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "compatible_families": {"$ref": "#/$defs/string_array"},
        "package_authorable": {"type": "boolean"},
        "required_scope": {"type": ["string", "null"], "minLength": 1},
        "target_capability": {"enum": ["forbidden", "required_capability_call_contract"]},
        "required_interfaces": {"$ref": "#/$defs/string_array"},
        "provided_interfaces": {"$ref": "#/$defs/string_array"},
        "lifecycle_profiles": {"$ref": "#/$defs/string_array"},
        "authority_profile": {
          "enum": ["none", "capability_scoped", "event_admission", "projection_source"]
        },
        "static_guarantees": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "deterministic",
              "contract_pinned",
              "no_runtime_inputs",
              "no_hidden_authority",
              "no_package_scheduler",
              "no_package_lifecycle",
              "no_direct_fact_write",
              "no_direct_rule_fire"
            ]
          }
        }
      }
    },
    "reserved_keyword_privilege": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyword",
        "library_id",
        "construct_family",
        "scope",
        "lowering_target"
      ],
      "properties": {
        "keyword": {"type": "string", "minLength": 1},
        "library_id": {"type": "string", "minLength": 1},
        "construct_family": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "lowering_target": {"type": "string", "minLength": 1}
      }
    },
    "span": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "path": {"type": ["string", "null"]},
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "construct": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "contract_registry": {
      "type": "object",
      "required": [
        "schema",
        "libraries",
        "constructs",
        "effect_contracts",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.contract_registry.v0"},
        "libraries": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "constructs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "effect_contracts": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "diagnostics": {
          "type": "array",
          "items": {"$ref": "#/$defs/contract_registry_diagnostic"}
        }
      },
      "additionalProperties": true
    },
    "package_contract": {
      "type": "object",
      "required": [
        "schema",
        "package_contract_digest",
        "package_lock_digest",
        "platform_version",
        "manifests",
        "platform_construct_catalog",
        "contract_registry",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.package_contract.v0"},
        "package_contract_digest": {"$ref": "#/$defs/digest"},
        "package_lock_digest": {"$ref": "#/$defs/digest"},
        "platform_version": {"$ref": "#/$defs/id"},
        "manifests": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "platform_construct_catalog": {"$ref": "#/$defs/platform_construct_catalog"},
        "contract_registry": {"$ref": "#/$defs/contract_registry"},
        "diagnostics": {
          "type": "array",
          "items": {"$ref": "#/$defs/contract_registry_diagnostic"}
        }
      },
      "additionalProperties": true
    },
    "construct_graph": {
      "type": "object",
      "required": [
        "schema",
        "graph_id",
        "platform_version",
        "package_lock_digest",
        "package_contract_digest",
        "source_digest",
        "nodes",
        "ports",
        "edges",
        "effect_dependencies",
        "derived_facts",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.construct_graph.v0"},
        "graph_id": {"$ref": "#/$defs/id"},
        "platform_version": {"$ref": "#/$defs/id"},
        "package_lock_digest": {"$ref": "#/$defs/digest"},
        "package_contract_digest": {"$ref": "#/$defs/digest"},
        "source_digest": {"$ref": "#/$defs/digest"},
        "nodes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "ports": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "edges": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "effect_dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "derived_facts": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/derived_fact"}
        },
        "diagnostics": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        }
      },
      "additionalProperties": true
    },
    "lowered_ir_report": {
      "type": "object",
      "required": [
        "schema",
        "graph_id",
        "accepted_program_digest",
        "lowerer_version",
        "package_lock_digest",
        "source_digest",
        "node_lowerings",
        "edge_lowerings",
        "dependency_lowerings",
        "core_objects",
        "derived_facts",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.lowered_ir_report.v0"},
        "graph_id": {"$ref": "#/$defs/id"},
        "accepted_program_digest": {"$ref": "#/$defs/digest"},
        "lowerer_version": {"$ref": "#/$defs/id"},
        "package_lock_digest": {"$ref": "#/$defs/digest"},
        "source_digest": {"$ref": "#/$defs/digest"},
        "node_lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "edge_lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "dependency_lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "core_objects": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "derived_facts": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/derived_fact"}
        },
        "diagnostics": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        }
      },
      "additionalProperties": true
    },
    "derived_fact": {
      "type": "object",
      "required": ["predicate", "owner_subsystem", "input_refs", "diagnostic_span"],
      "properties": {
        "predicate": {"type": "string", "minLength": 1},
        "owner_subsystem": {"type": "string", "minLength": 1},
        "input_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "diagnostic_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "contract_registry_diagnostic": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {"type": "string"},
        "message": {"type": "string"}
      },
      "additionalProperties": true
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "report_path",
        "report_schema",
        "source_path",
        "workflow",
        "source_hash",
        "ir_hash",
        "snapshot",
        "contract_registry",
        "package_contract"
      ],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "report_path": {"type": "string", "minLength": 1},
        "report_schema": {
          "type": "string",
          "enum": [
            "whipplescript.check_report.v0",
            "whipplescript.compile_report.v0"
          ]
        },
        "source_path": {"type": "string", "minLength": 1},
        "workflow": {"type": "string", "minLength": 1},
        "source_hash": {"$ref": "#/$defs/stable_digest"},
        "ir_hash": {"$ref": "#/$defs/stable_digest"},
        "snapshot": {"type": "string"},
        "contract_registry": {"$ref": "#/$defs/contract_registry"},
        "package_contract": {"$ref": "#/$defs/package_contract"},
        "construct_graph": {"$ref": "#/$defs/construct_graph"},
        "lowered_ir_report": {"$ref": "#/$defs/lowered_ir_report"}
      }
    }
  }
}
