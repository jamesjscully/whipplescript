{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.local/schemas/check_report_v0.schema.json",
  "title": "WhippleScript check report v0",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "type": "object",
        "required": [
          "schema",
          "path",
          "status",
          "workflow",
          "source_hash",
          "ir_hash",
          "snapshot",
          "source_metadata",
          "contract_registry",
          "package_contract",
          "construct_graph",
          "lowered_ir_report"
        ],
        "properties": {
          "schema": {"const": "whipplescript.check_report.v0"},
          "path": {"type": "string"},
          "status": {"const": "ok"},
          "workflow": {"type": "string"},
          "source_hash": {"$ref": "#/$defs/stable_digest"},
          "ir_hash": {"$ref": "#/$defs/stable_digest"},
          "snapshot": {"type": "string"},
          "source_metadata": {"$ref": "#/$defs/source_metadata"},
          "contract_registry": {"$ref": "#/$defs/contract_registry"},
          "package_contract": {"$ref": "#/$defs/package_contract"},
          "construct_graph": {"$ref": "#/$defs/construct_graph"},
          "lowered_ir_report": {"$ref": "#/$defs/lowered_ir_report"},
          "model_search": {"$ref": "#/$defs/model_search"},
          "ir_model_search_obligations": {"$ref": "#/$defs/ir_model_search_obligations"},
          "artifact_model_search_obligations": {"$ref": "#/$defs/artifact_model_search_obligations"}
        },
        "additionalProperties": true
      },
      {
        "type": "object",
        "required": ["schema", "path", "status", "error"],
        "properties": {
          "schema": {"const": "whipplescript.check_report.v0"},
          "path": {"type": "string"},
          "status": {"const": "error"},
          "error": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {"enum": ["io", "diagnostics", "package_lock", "construct_graph", "lowered_ir_report"]},
              "message": {"type": "string"},
              "diagnostics": {
                "type": "array",
                "items": {"$ref": "#/$defs/diagnostic"}
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    ]
  },
  "$defs": {
    "span": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "path": {"type": ["string", "null"]},
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "construct": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "id": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stable_digest": {"type": "string", "pattern": "^[0-9a-f]{16}$"},
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "platform_construct_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "families",
        "lowerings",
        "scopes",
        "field_kinds",
        "interface_kinds",
        "interface_phases",
        "interface_cardinalities",
        "reserved_keywords",
        "reserved_keyword_privileges"
      ],
      "properties": {
        "schema": {"const": "whipplescript.platform_construct_catalog.v0"},
        "families": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/platform_construct_family"}
        },
        "lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/platform_construct_lowering"}
        },
        "scopes": {"$ref": "#/$defs/string_array"},
        "field_kinds": {"$ref": "#/$defs/string_array"},
        "interface_kinds": {"$ref": "#/$defs/string_array"},
        "interface_phases": {"$ref": "#/$defs/string_array"},
        "interface_cardinalities": {"$ref": "#/$defs/string_array"},
        "reserved_keywords": {"$ref": "#/$defs/string_array"},
        "reserved_keyword_privileges": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/reserved_keyword_privilege"}
        }
      }
    },
    "platform_construct_family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "platform_construct_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "compatible_families",
        "package_authorable",
        "required_scope",
        "target_capability",
        "required_interfaces",
        "provided_interfaces",
        "lifecycle_profiles",
        "authority_profile",
        "static_guarantees"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "compatible_families": {"$ref": "#/$defs/string_array"},
        "package_authorable": {"type": "boolean"},
        "required_scope": {"type": ["string", "null"], "minLength": 1},
        "target_capability": {"enum": ["forbidden", "required_capability_call_contract"]},
        "required_interfaces": {"$ref": "#/$defs/string_array"},
        "provided_interfaces": {"$ref": "#/$defs/string_array"},
        "lifecycle_profiles": {"$ref": "#/$defs/string_array"},
        "authority_profile": {
          "enum": ["none", "capability_scoped", "event_admission", "projection_source"]
        },
        "static_guarantees": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "deterministic",
              "contract_pinned",
              "no_runtime_inputs",
              "no_hidden_authority",
              "no_package_scheduler",
              "no_package_lifecycle",
              "no_direct_fact_write",
              "no_direct_rule_fire"
            ]
          }
        }
      }
    },
    "reserved_keyword_privilege": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyword",
        "library_id",
        "construct_family",
        "scope",
        "lowering_target"
      ],
      "properties": {
        "keyword": {"type": "string", "minLength": 1},
        "library_id": {"type": "string", "minLength": 1},
        "construct_family": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "lowering_target": {"type": "string", "minLength": 1}
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["message", "source_span"],
      "properties": {
        "message": {"type": "string"},
        "suggestion": {"type": ["string", "null"]},
        "source_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "source_metadata": {
      "type": "object",
      "required": ["tags", "descriptions", "targets"],
      "properties": {
        "tags": {
          "type": "array",
          "items": {"$ref": "#/$defs/source_tag"}
        },
        "descriptions": {
          "type": "array",
          "items": {"$ref": "#/$defs/source_description"}
        },
        "targets": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/source_target"}
        }
      },
      "additionalProperties": true
    },
    "source_tag": {
      "type": "object",
      "required": ["name", "target_kind", "target", "source_span"],
      "properties": {
        "name": {"type": "string"},
        "target_kind": {"type": "string"},
        "target": {"type": "string"},
        "source_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "source_description": {
      "type": "object",
      "required": ["value", "target_kind", "target", "source_span"],
      "properties": {
        "value": {"type": "string"},
        "target_kind": {"type": "string"},
        "target": {"type": "string"},
        "source_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "source_target": {
      "type": "object",
      "required": ["target_kind", "target", "tags"],
      "properties": {
        "target_kind": {"type": "string"},
        "target": {"type": "string"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "description": {"type": "string"}
      },
      "additionalProperties": true
    },
    "contract_registry": {
      "type": "object",
      "required": [
        "schema",
        "libraries",
        "constructs",
        "effect_contracts",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.contract_registry.v0"},
        "libraries": {
          "type": "array",
          "items": {"$ref": "#/$defs/contract_registry_library"}
        },
        "constructs": {
          "type": "array",
          "items": {"$ref": "#/$defs/construct"}
        },
        "effect_contracts": {
          "type": "array",
          "items": {"$ref": "#/$defs/effect_contract"}
        },
        "diagnostics": {
          "type": "array",
          "items": {"$ref": "#/$defs/contract_registry_diagnostic"}
        }
      },
      "additionalProperties": true
    },
    "package_contract": {
      "type": "object",
      "required": [
        "schema",
        "package_contract_digest",
        "package_lock_digest",
        "platform_version",
        "manifests",
        "platform_construct_catalog",
        "contract_registry",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.package_contract.v0"},
        "package_contract_digest": {"$ref": "#/$defs/digest"},
        "package_lock_digest": {"$ref": "#/$defs/digest"},
        "platform_version": {"$ref": "#/$defs/id"},
        "manifests": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "platform_construct_catalog": {"$ref": "#/$defs/platform_construct_catalog"},
        "contract_registry": {"$ref": "#/$defs/contract_registry"},
        "diagnostics": {
          "type": "array",
          "items": {"$ref": "#/$defs/contract_registry_diagnostic"}
        }
      },
      "additionalProperties": true
    },
    "construct_graph": {
      "type": "object",
      "required": [
        "schema",
        "graph_id",
        "platform_version",
        "package_lock_digest",
        "package_contract_digest",
        "source_digest",
        "nodes",
        "ports",
        "edges",
        "effect_dependencies",
        "derived_facts",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.construct_graph.v0"},
        "graph_id": {"$ref": "#/$defs/id"},
        "platform_version": {"$ref": "#/$defs/id"},
        "package_lock_digest": {"$ref": "#/$defs/digest"},
        "package_contract_digest": {"$ref": "#/$defs/digest"},
        "source_digest": {"$ref": "#/$defs/digest"},
        "nodes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "ports": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "edges": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "effect_dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "derived_facts": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/derived_fact"}
        },
        "diagnostics": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        }
      },
      "additionalProperties": true
    },
    "lowered_ir_report": {
      "type": "object",
      "required": [
        "schema",
        "graph_id",
        "accepted_program_digest",
        "lowerer_version",
        "package_lock_digest",
        "source_digest",
        "node_lowerings",
        "edge_lowerings",
        "dependency_lowerings",
        "core_objects",
        "derived_facts",
        "diagnostics"
      ],
      "properties": {
        "schema": {"const": "whipplescript.lowered_ir_report.v0"},
        "graph_id": {"$ref": "#/$defs/id"},
        "accepted_program_digest": {"$ref": "#/$defs/digest"},
        "lowerer_version": {"$ref": "#/$defs/id"},
        "package_lock_digest": {"$ref": "#/$defs/digest"},
        "source_digest": {"$ref": "#/$defs/digest"},
        "node_lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "edge_lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "dependency_lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "core_objects": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "object", "additionalProperties": true}
        },
        "derived_facts": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/derived_fact"}
        },
        "diagnostics": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        }
      },
      "additionalProperties": true
    },
    "derived_fact": {
      "type": "object",
      "required": ["predicate", "owner_subsystem", "input_refs", "diagnostic_span"],
      "properties": {
        "predicate": {"type": "string", "minLength": 1},
        "owner_subsystem": {"type": "string", "minLength": 1},
        "input_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "diagnostic_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "model_search": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status",
            "searches",
            "solutions",
            "no_solutions",
            "ir_searches",
            "artifact_searches",
            "obligations"
          ],
          "properties": {
            "status": {"const": "ok"},
            "searches": {"type": "integer", "minimum": 0},
            "solutions": {"type": "integer", "minimum": 0},
            "no_solutions": {"type": "integer", "minimum": 0},
            "ir_searches": {"type": "integer", "minimum": 0},
            "artifact_searches": {"type": "integer", "minimum": 0},
            "obligations": {
              "type": "array",
              "items": {"$ref": "#/$defs/model_search_obligation"}
            }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["status", "message"],
          "properties": {
            "status": {"const": "error"},
            "message": {"type": "string"}
          },
          "additionalProperties": true
        }
      ]
    },
    "model_search_obligation": {
      "type": "object",
      "required": [
        "category",
        "index",
        "description",
        "upstream",
        "predicate",
        "downstream",
        "expected",
        "actual",
        "status",
        "source_span"
      ],
      "properties": {
        "category": {
          "enum": [
            "ir",
            "artifact.construct_graph",
            "artifact.lowered_ir",
            "artifact.platform_catalog"
          ]
        },
        "index": {"type": "integer", "minimum": 1},
        "description": {"type": "string", "minLength": 1},
        "upstream": {"type": "string", "minLength": 1},
        "predicate": {"type": "string", "minLength": 1},
        "downstream": {"type": "string", "minLength": 1},
        "expected": {"enum": ["solution", "no_solution"]},
        "actual": {"enum": ["solution", "no_solution"]},
        "status": {"const": "ok"},
        "source_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "ir_model_search_obligations": {
      "type": "object",
      "required": ["schema", "source_hash", "ir_hash", "generator", "obligations"],
      "properties": {
        "schema": {"const": "whipplescript.ir_model_search_obligations.v0"},
        "source_hash": {"$ref": "#/$defs/stable_digest"},
        "ir_hash": {"$ref": "#/$defs/stable_digest"},
        "generator": {"type": "string", "minLength": 1},
        "obligations": {
          "type": "array",
          "items": {"$ref": "#/$defs/ir_model_search_obligation"}
        }
      },
      "additionalProperties": true
    },
    "ir_model_search_obligation": {
      "type": "object",
      "required": [
        "index",
        "description",
        "upstream",
        "predicate",
        "downstream",
        "expected",
        "source_span"
      ],
      "properties": {
        "index": {"type": "integer", "minimum": 1},
        "description": {"type": "string", "minLength": 1},
        "upstream": {"type": "string", "minLength": 1},
        "predicate": {"type": "string", "minLength": 1},
        "downstream": {"type": "string", "minLength": 1},
        "expected": {"enum": ["solution", "no_solution"]},
        "source_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "artifact_model_search_obligations": {
      "type": "object",
      "required": [
        "schema",
        "source_hash",
        "ir_hash",
        "package_contract_digest",
        "construct_graph_id",
        "accepted_program_digest",
        "generator",
        "obligations"
      ],
      "properties": {
        "schema": {"const": "whipplescript.artifact_model_search_obligations.v0"},
        "source_hash": {"$ref": "#/$defs/stable_digest"},
        "ir_hash": {"$ref": "#/$defs/stable_digest"},
        "package_contract_digest": {"$ref": "#/$defs/digest"},
        "construct_graph_id": {"type": "string", "minLength": 1},
        "accepted_program_digest": {"$ref": "#/$defs/digest"},
        "generator": {"type": "string", "minLength": 1},
        "obligations": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_model_search_obligation"}
        }
      },
      "additionalProperties": true
    },
    "artifact_model_search_obligation": {
      "type": "object",
      "required": [
        "category",
        "index",
        "description",
        "upstream",
        "predicate",
        "downstream",
        "expected",
        "source_span"
      ],
      "properties": {
        "category": {
          "enum": [
            "artifact.construct_graph",
            "artifact.lowered_ir",
            "artifact.platform_catalog"
          ]
        },
        "index": {"type": "integer", "minimum": 1},
        "description": {"type": "string", "minLength": 1},
        "upstream": {"type": "string", "minLength": 1},
        "predicate": {"type": "string", "minLength": 1},
        "downstream": {"type": "string", "minLength": 1},
        "expected": {"enum": ["solution", "no_solution"]},
        "source_span": {"$ref": "#/$defs/span"}
      },
      "additionalProperties": true
    },
    "contract_registry_library": {
      "type": "object",
      "required": ["id", "version", "standard"],
      "properties": {
        "id": {"type": "string"},
        "version": {"type": "string"},
        "standard": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "construct": {
      "type": "object",
      "required": [
        "id",
        "library_id",
        "version",
        "construct_family",
        "keyword",
        "scope",
        "fields",
        "requires",
        "provides",
        "lowering_target"
      ],
      "properties": {
        "id": {"type": "string"},
        "library_id": {"type": "string"},
        "version": {"type": "string"},
        "construct_family": {"type": "string"},
        "keyword": {"type": "string"},
        "scope": {"type": "string"},
        "fields": {
          "type": "array",
          "items": {"$ref": "#/$defs/construct_field"}
        },
        "requires": {
          "type": "array",
          "items": {"$ref": "#/$defs/construct_interface"}
        },
        "provides": {
          "type": "array",
          "items": {"$ref": "#/$defs/construct_interface"}
        },
        "lowering_target": {"type": "string"},
        "target_capability": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "construct_interface": {
      "type": "object",
      "required": ["kind", "phase", "cardinality"],
      "properties": {
        "kind": {"type": "string"},
        "name": {"type": ["string", "null"]},
        "type": {"type": ["string", "null"]},
        "phase": {"type": "string"},
        "cardinality": {"type": "string"}
      },
      "additionalProperties": true
    },
    "construct_field": {
      "type": "object",
      "required": ["name", "kind", "required"],
      "properties": {
        "name": {"type": "string"},
        "kind": {"type": "string"},
        "required": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "effect_contract": {
      "type": "object",
      "required": [
        "id",
        "library_id",
        "version",
        "effect_kind",
        "source_forms",
        "required_capabilities",
        "provider_kinds",
        "projected_facts",
        "validation"
      ],
      "properties": {
        "id": {"type": "string"},
        "library_id": {"type": "string"},
        "version": {"type": "string"},
        "effect_kind": {"type": "string"},
        "source_forms": {
          "type": "array",
          "items": {"type": "string"}
        },
        "input_schema": {"type": ["string", "null"]},
        "output_schema": {"type": ["string", "null"]},
        "required_capabilities": {
          "type": "array",
          "items": {"type": "string"}
        },
        "provider_kinds": {
          "type": "array",
          "items": {"type": "string"}
        },
        "projected_facts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "validation": {
          "enum": ["none", "runtime_boundary"]
        }
      },
      "additionalProperties": true
    },
    "contract_registry_diagnostic": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {"type": "string"},
        "message": {"type": "string"}
      },
      "additionalProperties": true
    }
  }
}
