{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/lowered_ir_report_v0.schema.json",
  "title": "WhippleScript Lowered IR Report v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "graph_id",
    "accepted_program_digest",
    "lowerer_version",
    "package_lock_digest",
    "source_digest",
    "node_lowerings",
    "edge_lowerings",
    "dependency_lowerings",
    "core_objects",
    "derived_facts",
    "diagnostics"
  ],
  "properties": {
    "schema": {
      "const": "whipplescript.lowered_ir_report.v0"
    },
    "graph_id": {
      "$ref": "#/$defs/id"
    },
    "accepted_program_digest": {
      "$ref": "#/$defs/digest"
    },
    "lowerer_version": {
      "$ref": "#/$defs/id"
    },
    "package_lock_digest": {
      "$ref": "#/$defs/digest"
    },
    "source_digest": {
      "$ref": "#/$defs/digest"
    },
    "node_lowerings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/node_lowering"
      }
    },
    "edge_lowerings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/edge_lowering"
      }
    },
    "dependency_lowerings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/dependency_lowering"
      }
    },
    "core_objects": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/core_object"
      }
    },
    "derived_facts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/derived_fact"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "start", "end"],
      "properties": {
        "path": {
          "type": ["string", "null"]
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        },
        "construct": {
          "type": ["string", "null"]
        }
      }
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "node_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "lowering_class",
        "produced_core_object_refs",
        "preserved_source_span_refs",
        "preserved_resource_refs",
        "preserved_capability_refs",
        "preserved_version_refs",
        "preserved_cardinality_refs",
        "preserved_provenance_refs",
        "preserved_terminal_binding_refs"
      ],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/id"
        },
        "lowering_class": {
          "$ref": "#/$defs/id"
        },
        "produced_core_object_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_source_span_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_resource_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_capability_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_version_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_cardinality_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_provenance_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_terminal_binding_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        }
      }
    },
    "edge_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_port_id",
        "provided_port_id",
        "core_relation_ref",
        "produced_core_object_refs",
        "preserved_type_refs",
        "preserved_resource_refs",
        "preserved_capability_refs",
        "preserved_version_refs",
        "preserved_span_refs",
        "preserved_cardinality_refs",
        "preserved_provenance_refs"
      ],
      "properties": {
        "required_port_id": {
          "$ref": "#/$defs/id"
        },
        "provided_port_id": {
          "$ref": "#/$defs/id"
        },
        "core_relation_ref": {
          "$ref": "#/$defs/id"
        },
        "produced_core_object_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_type_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_resource_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_capability_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_version_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_span_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_cardinality_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_provenance_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        }
      }
    },
    "dependency_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_ref",
        "produced_core_object_refs",
        "preserved_effect_refs",
        "preserved_predicate",
        "preserved_span_refs",
        "preserved_provenance_refs"
      ],
      "properties": {
        "dependency_ref": {
          "$ref": "#/$defs/id"
        },
        "produced_core_object_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_effect_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_predicate": {
          "enum": ["succeeds", "fails", "completes"]
        },
        "preserved_span_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "preserved_provenance_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        }
      }
    },
    "core_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_kind",
        "object_id",
        "owner_kind",
        "owner_ref",
        "runtime_entrypoint",
        "source_span"
      ],
      "properties": {
        "object_kind": {
          "enum": [
            "fact",
            "event",
            "signal_source",
            "clock_source",
            "schedule",
            "effect",
            "rule",
            "dependency",
            "projection",
            "assertion",
            "diagnostic"
          ]
        },
        "runtime_entrypoint": {
          "enum": [
            "fact_record",
            "event_record",
            "signal_source_template",
            "clock_source_template",
            "schedule_template",
            "effect_graph_template",
            "rule_template",
            "effect_dependency_template",
            "event_projection",
            "assertion_check",
            "diagnostic_record"
          ]
        },
        "object_id": {
          "$ref": "#/$defs/id"
        },
        "owner_kind": {
          "enum": ["node", "edge", "dependency"]
        },
        "owner_ref": {
          "$ref": "#/$defs/id"
        },
        "source_span": {
          "$ref": "#/$defs/span"
        },
        "resource_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "capability_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "version_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "entrypoint_refs": {
          "$ref": "#/$defs/entrypoint_refs"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "fact"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "fact_record"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/fact_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "event"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "event_record"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/event_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "signal_source"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "signal_source_template"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/signal_source_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "clock_source"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "clock_source_template"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/clock_source_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "schedule"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "schedule_template"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/schedule_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "effect"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "properties": {
              "runtime_entrypoint": {
                "const": "effect_graph_template"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "rule"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "rule_template"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/rule_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "dependency"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "owner_kind": {
                "const": "dependency"
              },
              "runtime_entrypoint": {
                "const": "effect_dependency_template"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/dependency_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "projection"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "event_projection"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/projection_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "assertion"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "assertion_check"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/assertion_entrypoint_refs"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "object_kind": {
                "const": "diagnostic"
              }
            },
            "required": ["object_kind"]
          },
          "then": {
            "required": ["entrypoint_refs"],
            "properties": {
              "runtime_entrypoint": {
                "const": "diagnostic_record"
              },
              "entrypoint_refs": {
                "$ref": "#/$defs/diagnostic_entrypoint_refs"
              }
            }
          }
        }
      ]
    },
    "entrypoint_refs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/id"
      }
    },
    "fact_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact", "schema"],
      "properties": {
        "fact": {
          "$ref": "#/$defs/id"
        },
        "schema": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "dependency_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upstream_effect", "predicate", "downstream_effect"],
      "properties": {
        "upstream_effect": {
          "$ref": "#/$defs/id"
        },
        "predicate": {
          "enum": ["succeeds", "fails", "completes"]
        },
        "downstream_effect": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "signal_source_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event"],
      "properties": {
        "event": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "clock_source_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event"],
      "properties": {
        "event": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "event_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event"],
      "properties": {
        "event": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "projection_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "fact"],
      "properties": {
        "event": {
          "$ref": "#/$defs/id"
        },
        "fact": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "diagnostic_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule"],
      "properties": {
        "rule": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "schedule_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schedule"],
      "properties": {
        "schedule": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "rule_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "fact", "graph"],
      "properties": {
        "rule": {
          "$ref": "#/$defs/id"
        },
        "fact": {
          "$ref": "#/$defs/id"
        },
        "graph": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "assertion_entrypoint_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertion"],
      "properties": {
        "assertion": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "derived_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "owner_subsystem", "input_refs", "diagnostic_span"],
      "properties": {
        "predicate": {
          "$ref": "#/$defs/id"
        },
        "owner_subsystem": {
          "$ref": "#/$defs/id"
        },
        "input_refs": {
          "$ref": "#/$defs/string_array",
          "uniqueItems": true
        },
        "diagnostic_span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "refs", "source_span"],
      "properties": {
        "code": {
          "$ref": "#/$defs/id"
        },
        "severity": {
          "enum": ["error", "warning", "info", "hint"]
        },
        "refs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/string_array"
          }
        },
        "source_span": {
          "$ref": "#/$defs/span"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
