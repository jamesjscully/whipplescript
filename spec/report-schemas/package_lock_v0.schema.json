{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/package_lock_v0.schema.json",
  "title": "WhippleScript Package Lock v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "packages"],
  "properties": {
    "schema": {
      "const": "whipplescript.package_lock.v0"
    },
    "packages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "package_id",
          "name",
          "version",
          "source",
          "manifest_sha256"
        ],
        "properties": {
          "package_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "$ref": "#/$defs/source"
          },
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "const": "path"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^/)|(^[A-Za-z]:)|(^|/)\\.\\.(/|$)"
          }
        }
      }
    }
  }
}
