{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whipplescript.dev/schemas/package_check_v0.schema.json",
  "title": "WhippleScript Package Check Report v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status"],
  "properties": {
    "schema": {
      "const": "whipplescript.package_check.v0"
    },
    "status": {
      "enum": ["ok", "error"]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "manifests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "package_id", "name", "version", "manifest_sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "package_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "platform_construct_catalog": {
      "$ref": "#/$defs/platform_construct_catalog"
    },
    "contract_registry": {
      "$ref": "#/$defs/contract_registry"
    },
    "package_contract": {
      "$ref": "#/$defs/package_contract"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ok"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": [
          "schema",
          "status",
          "platform_construct_catalog",
          "manifests",
          "contract_registry",
          "package_contract"
        ]
      }
    }
  ],
  "$defs": {
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "platform_construct_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "families",
        "lowerings",
        "scopes",
        "field_kinds",
        "interface_kinds",
        "interface_phases",
        "interface_cardinalities",
        "reserved_keywords",
        "reserved_keyword_privileges"
      ],
      "properties": {
        "schema": {
          "const": "whipplescript.platform_construct_catalog.v0"
        },
        "families": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/platform_construct_family"
          }
        },
        "lowerings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/platform_construct_lowering"
          }
        },
        "scopes": {
          "$ref": "#/$defs/string_array"
        },
        "field_kinds": {
          "$ref": "#/$defs/string_array"
        },
        "interface_kinds": {
          "$ref": "#/$defs/string_array"
        },
        "interface_phases": {
          "$ref": "#/$defs/string_array"
        },
        "interface_cardinalities": {
          "$ref": "#/$defs/string_array"
        },
        "reserved_keywords": {
          "$ref": "#/$defs/string_array"
        },
        "reserved_keyword_privileges": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reserved_keyword_privilege"
          }
        }
      }
    },
    "platform_construct_family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform_construct_lowering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "compatible_families",
        "package_authorable",
        "required_scope",
        "target_capability",
        "required_interfaces",
        "provided_interfaces",
        "lifecycle_profiles",
        "authority_profile",
        "static_guarantees"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "compatible_families": {
          "$ref": "#/$defs/string_array"
        },
        "package_authorable": {
          "type": "boolean"
        },
        "required_scope": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "target_capability": {
          "enum": ["forbidden", "required_capability_call_contract"]
        },
        "required_interfaces": {
          "$ref": "#/$defs/string_array"
        },
        "provided_interfaces": {
          "$ref": "#/$defs/string_array"
        },
        "lifecycle_profiles": {
          "$ref": "#/$defs/string_array"
        },
        "authority_profile": {
          "enum": [
            "none",
            "capability_scoped",
            "event_admission",
            "projection_source"
          ]
        },
        "static_guarantees": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "deterministic",
              "contract_pinned",
              "no_runtime_inputs",
              "no_hidden_authority",
              "no_package_scheduler",
              "no_package_lifecycle",
              "no_direct_fact_write",
              "no_direct_rule_fire"
            ]
          }
        }
      }
    },
    "reserved_keyword_privilege": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyword",
        "library_id",
        "construct_family",
        "scope",
        "lowering_target"
      ],
      "properties": {
        "keyword": {
          "type": "string",
          "minLength": 1
        },
        "library_id": {
          "type": "string",
          "minLength": 1
        },
        "construct_family": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "lowering_target": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contract_registry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "libraries",
        "constructs",
        "effect_contracts",
        "diagnostics"
      ],
      "properties": {
        "schema": {
          "const": "whipplescript.contract_registry.v0"
        },
        "libraries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract_registry_library"
          }
        },
        "constructs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct"
          }
        },
        "effect_contracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect_contract"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract_registry_diagnostic"
          }
        }
      }
    },
    "package_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "package_contract_digest",
        "package_lock_digest",
        "platform_version",
        "manifests",
        "platform_construct_catalog",
        "contract_registry",
        "diagnostics"
      ],
      "properties": {
        "schema": {
          "const": "whipplescript.package_contract.v0"
        },
        "package_contract_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "package_lock_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "platform_version": {
          "type": "string",
          "minLength": 1
        },
        "manifests": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "platform_construct_catalog": {
          "$ref": "#/$defs/platform_construct_catalog"
        },
        "contract_registry": {
          "$ref": "#/$defs/contract_registry"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract_registry_diagnostic"
          }
        }
      }
    },
    "contract_registry_library": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "version", "standard"],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "standard": {
          "type": "boolean"
        }
      }
    },
    "construct": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "library_id",
        "version",
        "construct_family",
        "keyword",
        "scope",
        "fields",
        "requires",
        "provides",
        "lowering_target"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "library_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "construct_family": {
          "type": "string"
        },
        "keyword": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct_field"
          }
        },
        "requires": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct_interface"
          }
        },
        "provides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct_interface"
          }
        },
        "lowering_target": {
          "type": "string"
        },
        "target_capability": {
          "type": ["string", "null"]
        }
      }
    },
    "construct_interface": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "phase", "cardinality"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "name": {
          "type": ["string", "null"]
        },
        "type": {
          "type": ["string", "null"]
        },
        "phase": {
          "type": "string"
        },
        "cardinality": {
          "type": "string"
        }
      }
    },
    "construct_field": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "kind", "required"],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "effect_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "library_id",
        "version",
        "effect_kind",
        "source_forms",
        "required_capabilities",
        "provider_kinds",
        "projected_facts",
        "validation"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "library_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "effect_kind": {
          "type": "string"
        },
        "source_forms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_schema": {
          "type": ["string", "null"]
        },
        "output_schema": {
          "type": ["string", "null"]
        },
        "required_capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provider_kinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_facts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation": {
          "enum": ["none", "runtime_boundary"]
        }
      }
    },
    "contract_registry_diagnostic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
