      "provider_kind": "builtin-coordination",
      "capability": "counter.consume",
      "effect_kind": "counter.consume",
      "config": {}
    }
  ],
  "profiles": [
    {
      "id": "profile-coordination-user",
      "name": "coordination-user",
      "description": "Allow the workspace-scoped coordination effects (lease / ledger / counter).",
      "enforcement_mode": "enforce",
      "allowed_capabilities": [
        "lease.acquire",
        "lease.release",
        "lease.renew",
        "ledger.append",
        "counter.consume"
      ],
      "config": {}
    }
  ],
  "bindings": [
    {
      "id": "binding-coord-lease-acquire",
      "program_id": null,
      "capability": "lease.acquire",
      "provider": "builtin-coordination",
      "config": {}
    },
    {
      "id": "binding-coord-lease-release",
      "program_id": null,
