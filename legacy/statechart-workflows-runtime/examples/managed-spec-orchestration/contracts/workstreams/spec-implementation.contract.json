{
  "contractVersion": 1,
  "extends": "../repo.contract.json",
  "scope": {
    "type": "workstream",
    "id": "spec-implementation"
  },
  "state": {
    "authoritativeFiles": [
      "state/implementation-plan.json"
    ],
    "specRoots": [
      "specs/01-overview.md",
      "specs/02-database.md",
      "specs/03-auth.md",
      "specs/04-api.md",
      "specs/05-websocket.md",
      "specs/06-pi-integration.md",
      "specs/08-workspace.md",
      "specs/15-task-queue.md",
      "specs/16-agent-policy-and-control-plane.md"
    ],
    "artifactPaths": [
      "artifacts/spec-implementation/**"
    ]
  },
  "lifecycle": {
    "maxActiveThreads": 3,
    "maxActivePerArea": 1,
    "heartbeatEvery": "90s",
    "staleAfter": "8m",
    "retryLimit": 2
  },
  "prompts": {
    "director": "builder_only/orchestration/prompts/spec-director.md",
    "worker": "builder_only/orchestration/prompts/spec-worker.md",
    "qualityGate": "builder_only/orchestration/prompts/spec-quality-gate.md"
  },
  "quality": {
    "requiredCommands": [
      "npm run typecheck",
      "npm test"
    ],
    "acceptanceChecklist": [
      "Implementation matches the referenced spec section.",
      "State transitions are explicit and recoverable.",
      "Permission checks follow the contract boundary.",
      "Tests cover the changed behavior or the ledger records why not.",
      "No hidden workflow state is introduced outside the ledger."
    ]
  }
}
