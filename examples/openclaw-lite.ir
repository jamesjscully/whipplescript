workflow OpenClawLite
source_tags
@service workflow OpenClawLite
schemas
  class Heartbeat
    job string
    status literal<"observed">
  class Plan
    title string
    summary string
    status literal<"ready">
queues
  queue backlog tracker=builtin
agents
  agent planner harness=<fallback> provider=codex profile=repo-reader capacity=1 skills=[] capabilities=[]
  agent reviewer harness=<fallback> provider=claude profile=repo-reader capacity=1 skills=[] capabilities=[]
assertions
  assert count(Heartbeat where status == "observed") == 1
    reads
      fact:Heartbeat where status == "observed"
  assert count(Plan where status == "ready") == 1
    reads
      fact:Plan where status == "ready"
  assert count(effect kind queue.file where status == completed) == 1
    reads
      effect:kind queue.file where status == completed
rules
  rule observe_heartbeat
    when started
    reads
      pattern:started
    writes
      schema:Heartbeat
    body_hash 66ebf556cd43442b
  rule plan_recurring_work
    when Heartbeat as beat where beat.status == "observed"
    when planner is available
    reads
      pattern:planner is available
      schema:Heartbeat
    writes
      schema:Plan
    effects
      planTurn kind=agent.tell binding=planTurn key=97a3c1a4726b15f5
      effect2 kind=queue.file binding=- key=297a57f0b754728a
    dependencies
      planTurn --succeeds--> effect2
    body_hash 4c44573435143a42
  rule escalate_plan_for_review
    when Plan as plan where plan.status == "ready"
    when reviewer is available
    reads
      pattern:reviewer is available
      schema:Plan
    effects
      effect1 kind=human.ask binding=- key=354295ddaf3d196e
    body_hash f9342bbc7ed9e7fa
rule_dependencies
  observe_heartbeat --schema:Heartbeat--> plan_recurring_work
  plan_recurring_work --schema:Plan--> escalate_plan_for_review
