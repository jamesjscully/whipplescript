workflow CodexPoemCoerceReview
uses
  skill baml-coerce-user
schemas
  class PoemRequest
    topic string
    poemPath string
    status literal<"queued">
  class FrenchPoemReview
    isFrench bool
    isPoem bool
    reason string
    confidence float
  class ReviewedPoem
    topic string
    poemPath string
    turn ref<AgentTurn>
    review ref<FrenchPoemReview>
    status literal<"reviewed">
agents
  agent codex profile=repo-writer capacity=1 skills=[] capabilities=[]
coerces
  coerce reviewFrenchPoem(topic string, poemPath string, turnSummary string) -> ref<FrenchPoemReview>
assertions
  assert none(PoemRequest where status == "queued")
    reads
      fact:PoemRequest where status == "queued"
  assert one(ReviewedPoem where status == "reviewed")
    reads
      fact:ReviewedPoem where status == "reviewed"
  assert one(effect kind agent.tell where status == completed)
    reads
      effect:kind agent.tell where status == completed
  assert one(effect kind baml.coerce where status == completed)
    reads
      effect:kind baml.coerce where status == completed
rules
  rule seed_poem_request
    when started
    reads
      pattern:started
    writes
      schema:PoemRequest
    body_hash 746bc0a67ce23a00
  rule write_and_review_poem
    when PoemRequest as request where request.status == "queued"
    when codex is available
    reads
      pattern:codex is available
      schema:PoemRequest
    writes
      schema:ReviewedPoem
    consumes
      schema:PoemRequest
    effects
      poemTurn kind=agent.tell binding=poemTurn key=c99af6aeb446d4ca
      review kind=baml.coerce binding=review key=fadf644fc82dc8bf
    dependencies
      poemTurn --succeeds--> review
    body_hash ef05d61608811ff7
rule_dependencies
  seed_poem_request --schema:PoemRequest--> write_and_review_poem
