workflow ExpressionKernelDogfood

class KernelOwner {
  name string
}

class KernelTask {
  provider AgentRef<codex | claude | pi>
  title string
  status "queued" | "blocked" | "done"
  route string
  tags string[]
  metadata map<string>
  owner KernelOwner?
  attempts int
  priority int
}

class KernelRoute {
  provider string
  title string
  owner KernelOwner?
  status "routed"
}

agent codex {
  profile "repo-writer"
  capacity 1
}

agent claude {
  profile "repo-writer"
  capacity 1
}

agent pi {
  profile "repo-reader"
  capacity 1
}

assert count(KernelTask where status == "queued") == 3
assert count(KernelRoute where provider in ["codex", "claude", "pi"]) == 3
assert exists(KernelTask where route == "docs" && "expression-kernel" in tags)
assert empty(KernelTask where status == "blocked" || priority > 9)
assert count(KernelTask where "phase" in metadata && metadata["phase"] == "kernel") >= 1
assert exists(KernelTask where owner != null && owner.name == "Ada")
assert count(effect kind agent.tell where status == completed) == 3

rule seed_expression_kernel_tasks
  when started
=> {
  record KernelTask {
    provider "codex"
    title "Implement expression guards"
    status "queued"
    route "code"
    tags ["expression-kernel", "guards"]
    metadata { phase "kernel" }
    owner null
    attempts 0
    priority 3
  }

  record KernelTask {
    provider "claude"
    title "Review expression assertions"
    status "queued"
    route "review"
    tags ["expression-kernel", "assertions"]
    metadata { phase "kernel" }
    owner null
    attempts 1
    priority 2
  }

  record KernelTask {
    provider "pi"
    title "Summarize expression docs"
    status "queued"
    route "docs"
    tags ["expression-kernel", "docs"]
    metadata { phase "kernel" }
    owner null
    attempts 0
    priority 1
  }
}

rule route_expression_kernel_task
  when KernelTask as task where task.status == "queued" && task.route in ["code", "review", "docs"] && "expression-kernel" in task.tags && "phase" in task.metadata && task.metadata["phase"] == "kernel" && (task.owner == null || exists task.owner) && !(task.priority > 5)
  when task.provider is available
=> {
  tell task.provider as turn """
  Handle this deterministic expression-kernel task.

  Title:
  {{ task.title }}

  Route:
  {{ task.route }}
  """

  after turn succeeds {
    record KernelRoute {
      provider task.provider
      title task.title
      owner task.owner
      status "routed"
    }
  }
}

rule route_owned_expression_kernel_task
  when KernelTask as task where exists task.owner && task.owner.name == "Ada" && task.metadata["phase"] not in ["deferred", "blocked"]
  when task.provider is available
=> {
  tell task.provider """
  Handle owned expression-kernel task for {{ task.owner.name }}:

  {{ task.title }}
  """
}

rule notice_routed_codex_task
  when KernelTask as task where task.provider == "codex" && exists(KernelRoute where provider == "codex")
=> {
}
