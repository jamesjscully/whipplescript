@service
description "Two agents with bounded capacity handing work to each other through a queue"
workflow MultiAgentBoundedConcurrency

# Agent capacity is part of matching, so dispatch naturally back-pressures.
queue backlog {
  tracker builtin
}

agent implementer {
  provider codex
  profile "repo-writer"
  capacity 2
}

agent reviewer {
  provider claude
  profile "repo-reader"
  capacity 1
}

rule implement_ready_work
  when backlog has ready item as item
  when implementer is available
=> {
  claim item as lease

  after lease succeeds {
    tell implementer as turn """markdown
    Implement this work item:

    {{ item.title }}

    {{ item.body }}
    """
  }

  after turn succeeds as outcome {
    finish item {
      summary outcome.summary
    }
  }
}

rule review_completed_turn
  when implementer completed turn as turn
  when reviewer is available
=> {
  tell reviewer """markdown
  Review this completed turn:

  {{ turn.summary }}
  """
}
