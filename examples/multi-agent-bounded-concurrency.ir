workflow MultiAgentBoundedConcurrency
source_tags
@service workflow MultiAgentBoundedConcurrency
source_descriptions
"Two agents with bounded capacity handing work to each other through a queue" workflow MultiAgentBoundedConcurrency
queues
  queue backlog tracker=builtin
agents
  agent implementer harness=<fallback> provider=codex profile=repo-writer capacity=2 skills=[] capabilities=[]
  agent reviewer harness=<fallback> provider=claude profile=repo-reader capacity=1 skills=[] capabilities=[]
rules
  rule implement_ready_work
    when backlog has ready item as item
    when implementer is available
    reads
      pattern:backlog has ready item as item
      pattern:implementer is available
    effects
      lease kind=queue.claim binding=lease key=e0d536a1a81513be
      turn kind=agent.tell binding=turn key=5b6982b2c1404341
      effect3 kind=queue.finish binding=- key=22fd3dde78d9ffee
    dependencies
      lease --succeeds--> turn
      turn --succeeds--> effect3
    body_hash a9870df894e15fbb
  rule review_completed_turn
    when implementer completed turn as turn
    when reviewer is available
    reads
      pattern:implementer completed turn as turn
      pattern:reviewer is available
    effects
      effect1 kind=agent.tell binding=- key=00a9ca48408507d3
    body_hash a64e9c44db33e30d
