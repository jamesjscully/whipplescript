machine BamlCoerceSmoke
initial waiting

data {
  reason string? = nil
}

event classify {
  text string
}

class Classification {
  kind string
  reason string
}

coerce classifyText(text string) -> Classification {
  model "gpt-4o-mini"

  prompt """
  Classify this short text for an orchestration smoke test.

  {{ text }}

  Return a concise reason.

  {{ ctx.output_format }}
  """
}

state waiting {
  on classify as evt {
    let result = coerce classifyText(evt.text)
    assign data.reason = result.reason
    goto done
  }
}

state done {
  final
}
