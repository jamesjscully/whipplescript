source_descriptions
"Fixture-backed provider x language acceptance workflow" workflow ProviderLanguageE2E
"Codex completes both assigned language tasks" assertion a219774c2ee6f69f
"Claude completes both assigned language tasks" assertion 5e025ac90573be72
"Pi completes both assigned language tasks" assertion c85987961124ce71
"All seeded language tasks are consumed" assertion 78aac8e288a30964
"All agent turns complete" assertion 680e3adc36120f16
"All language reviews complete" assertion e322246c5ed8c345
"Static provider x language task rows" table language_tasks
"Route one queued language task to its selected provider" rule run_language_task
schemas
  class LanguageTask
    provider agentref<codex | claude | pi>
    language string
    expectedScript string
    prompt string
    artifactPath string
    status literal<"queued">
  class LanguageQualityReview
    isTargetLanguage bool
    usesExpectedScript bool
    isWellFormed bool
    reason string
    confidence float
  class LanguageE2EResult
    provider string
    language string
    artifactPath string
    turn ref<AgentTurn>
    review ref<LanguageQualityReview>
    status literal<"reviewed">
agents
  agent codex harness=<fallback> provider=codex profile=repo-writer capacity=2 skills=[] capabilities=[]
  agent claude harness=<fallback> provider=claude profile=repo-writer capacity=2 skills=[] capabilities=[]
  agent pi harness=<fallback> provider=pi profile=repo-writer capacity=2 skills=[] capabilities=[]
coerces
  coerce reviewLanguageArtifact(language string, expectedScript string, artifactPath string, turnSummary string) -> ref<LanguageQualityReview>
assertions
  assert count(LanguageE2EResult where provider == "codex") == 2
    reads
      fact:LanguageE2EResult where provider == "codex"
  assert count(LanguageE2EResult where provider == "claude") == 2
    reads
      fact:LanguageE2EResult where provider == "claude"
  assert count(LanguageE2EResult where provider == "pi") == 2
    reads
      fact:LanguageE2EResult where provider == "pi"
  assert count(LanguageTask where status == "queued") == 0
    reads
      fact:LanguageTask where status == "queued"
  assert count(effect kind agent.tell where status == completed) == 6
    reads
      effect:kind agent.tell where status == completed
  assert count(effect kind baml.coerce where status == completed) == 6
    reads
      effect:kind baml.coerce where status == completed
rules
  rule table_language_tasks
    when started
    reads
      pattern:started
    writes
      schema:LanguageTask
    record_sources
      schema:LanguageTask construct=table_row span=2189..2420
      schema:LanguageTask construct=table_row span=2424..2647
      schema:LanguageTask construct=table_row span=2651..2877
      schema:LanguageTask construct=table_row span=2881..3106
      schema:LanguageTask construct=table_row span=3110..3344
      schema:LanguageTask construct=table_row span=3348..3564
    body_hash c7caf87da16ccacc
  rule run_language_task
    when LanguageTask as task where task.status == "queued"
    when task.provider is available
    reads
      pattern:task.provider is available
      schema:LanguageTask
    writes
      schema:LanguageE2EResult
    consumes
      schema:LanguageTask
    effects
      turn kind=agent.tell binding=turn key=dcc419597b331e20
      review kind=baml.coerce binding=review key=2ffc7caad53c6757
    dependencies
      turn --succeeds--> review
    body_hash 8e33bd71144e3452
rule_dependencies
  table_language_tasks --schema:LanguageTask--> run_language_task
