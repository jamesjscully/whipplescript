source_descriptions
"Fixture-backed provider x language acceptance workflow" workflow ProviderLanguageE2E
"Codex completes both assigned language tasks" assertion a219774c2ee6f69f
"Claude completes both assigned language tasks" assertion 5e025ac90573be72
"All seeded language tasks are consumed" assertion 78aac8e288a30964
"All agent turns complete" assertion 680e38dc36120bb0
"All language reviews complete" assertion 6d151ee02288805e
"Static provider x language task rows" table language_tasks
"Route one queued language task to its selected provider" rule run_language_task
schemas
  class LanguageTask
    provider agentref<codex | claude>
    language string
    expectedScript string
    prompt string
    artifactPath string
    status literal<"queued">
  class LanguageQualityReview
    isTargetLanguage bool
    usesExpectedScript bool
    isWellFormed bool
    reason string
    confidence float
  class LanguageE2EResult
    provider string
    language string
    artifactPath string
    turn ref<AgentTurn>
    review ref<LanguageQualityReview>
    status literal<"reviewed">
agents
  agent codex harness=<fallback> provider=codex profile=repo-writer capacity=2 skills=[] capabilities=[] tools=[] class=delegated
  agent claude harness=<fallback> provider=claude profile=repo-writer capacity=2 skills=[] capabilities=[] tools=[] class=delegated
coerces
  coerce reviewLanguageArtifact(language string, expectedScript string, artifactPath string, turnSummary string) -> ref<LanguageQualityReview>
assertions
  assert count(LanguageE2EResult where provider == "codex") == 2
    reads
      fact:LanguageE2EResult where provider == "codex"
  assert count(LanguageE2EResult where provider == "claude") == 2
    reads
      fact:LanguageE2EResult where provider == "claude"
  assert count(LanguageTask where status == "queued") == 0
    reads
      fact:LanguageTask where status == "queued"
  assert count(effect kind agent.tell where status == completed) == 4
    reads
      effect:kind agent.tell where status == completed
  assert count(effect kind schema.coerce where status == completed) == 4
    reads
      effect:kind schema.coerce where status == completed
rules
  rule table_language_tasks
    when started
    reads
      pattern:started
    writes
      schema:LanguageTask
    record_sources
      schema:LanguageTask construct=table_row span=1993..2224
      schema:LanguageTask construct=table_row span=2228..2451
      schema:LanguageTask construct=table_row span=2455..2681
      schema:LanguageTask construct=table_row span=2685..2910
    body_hash 762318eb56dea822
  rule run_language_task
    when LanguageTask as task where task.status == "queued"
    when task.provider is available
    reads
      pattern:task.provider is available
      schema:LanguageTask
    writes
      schema:LanguageE2EResult
    consumes
      schema:LanguageTask
    effects
      turn kind=agent.tell binding=turn key=dcc419597b331e20
      review kind=schema.coerce binding=review key=46ffc1fc9cbe8a58
    dependencies
      turn --succeeds--> review
    body_hash 8e33bd71144e3452
rule_dependencies
  table_language_tasks --schema:LanguageTask--> run_language_task
