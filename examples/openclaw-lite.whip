@service
workflow OpenClawLite

# `use std.memory` pulls in the embedded `std.memory` package (capabilities
# `memory.query`/`memory.write`); std packages ship compiled into the platform,
# so only the import is needed — no `whip.lock`. The planner recalls prior
# context before planning and saves the new plan after, so successive runs build
# on what came before instead of starting cold.
use std.memory
use std.tracker

class Heartbeat {
  job string
  status "observed"
}

class Plan {
  title string
  summary string
  status "ready"
}

class ReviewDecision {
  decision string
  decidedBy string
}

tracker backlog {
  provider builtin
}

agent planner {
  provider codex
  profile "repo-reader"
  capacity 1
}

agent reviewer {
  provider claude
  profile "repo-reader"
  capacity 1
}

assert count(Heartbeat where status == "observed") == 1

assert count(Plan where status == "ready") == 1

assert count(effect kind tracker.file where status == completed) == 1

# OpenClaw-like scheduling is modeled as an ordinary observed heartbeat.
rule observe_heartbeat
  when started
=> {
  record Heartbeat {
    job "openclaw-lite"
    status "observed"
  }
}

rule plan_recurring_work
  when Heartbeat as beat where beat.status == "observed"
  when planner is available
=> {
  call memory.query for beat as context

  after context succeeds as recalled {
    tell planner as planTurn """markdown
    Recalled context from earlier runs:

    {{ recalled.count }} prior notes are on file for pool {{ recalled.pool }}.

    Produce one concrete maintenance task for {{ beat.job }}.
    """
  }

  after planTurn succeeds as planned {
    record Plan {
      title "Review stale automation"
      summary planned.summary
      status "ready"
    }

    file issue into backlog {
      title "Review stale automation"
      body planned.summary
    }

    call memory.write for planned
  }
}

rule escalate_plan_for_review
  when Plan as plan where plan.status == "ready"
  when reviewer is available
=> {
  askHuman as review choices ["approve", "revise"] """markdown
  Review the generated maintenance plan:

  {{ plan.summary }}
  """
}

# Record the reviewer's decision once the inbox item is answered.
rule record_review_decision
  when human answered review as answer
=> {
  record ReviewDecision {
    decision answer.choice
    decidedBy answer.answered_by
  }
}
