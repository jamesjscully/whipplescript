@service
workflow OpenClawLite

class Heartbeat {
  job string
  status "observed"
}

class Plan {
  title string
  summary string
  status "ready"
}

queue backlog {
  tracker builtin
}

agent planner {
  provider codex
  profile "repo-reader"
  capacity 1
}

agent reviewer {
  provider claude
  profile "repo-reader"
  capacity 1
}

assert count(Heartbeat where status == "observed") == 1
assert count(Plan where status == "ready") == 1
assert count(effect kind queue.file where status == completed) == 1

# OpenClaw-like scheduling is modeled as an ordinary observed heartbeat.
rule observe_heartbeat
  when started
=> {
  record Heartbeat {
    job "openclaw-lite"
    status "observed"
  }
}

rule plan_recurring_work
  when Heartbeat as beat where beat.status == "observed"
  when planner is available
=> {
  tell planner as planTurn """markdown
  Produce one concrete maintenance task for {{ beat.job }}.
  """

  after planTurn succeeds as planned {
    record Plan {
      title "Review stale automation"
      summary planned.summary
      status "ready"
    }

    file item into backlog {
      title "Review stale automation"
      body planned.summary
    }
  }
}

rule escalate_plan_for_review
  when Plan as plan where plan.status == "ready"
  when reviewer is available
=> {
  askHuman choices ["approve", "revise"] """markdown
  Review the generated maintenance plan:

  {{ plan.summary }}
  """
}
