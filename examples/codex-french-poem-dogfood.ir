workflow CodexFrenchPoemDogfood
schemas
  class FrenchPoemRequest
    topic string
    poemPath string
    verdictPath string
    status literal<"queued">
  class FrenchPoemDraft
    topic string
    poemPath string
    verdictPath string
    turn ref<AgentTurn>
    status literal<"written">
  class FrenchPoemJudgment
    poemPath string
    verdictPath string
    turn ref<AgentTurn>
    status literal<"judged">
agents
  agent codex harness=<fallback> profile=repo-writer capacity=1 skills=[] capabilities=[]
assertions
  assert count(FrenchPoemRequest where status == "queued") == 0
    reads
      fact:FrenchPoemRequest where status == "queued"
  assert count(FrenchPoemDraft where status == "written") == 0
    reads
      fact:FrenchPoemDraft where status == "written"
  assert count(FrenchPoemJudgment where status == "judged") == 1
    reads
      fact:FrenchPoemJudgment where status == "judged"
  assert count(effect kind agent.tell where status == completed) == 2
    reads
      effect:kind agent.tell where status == completed
rules
  rule seed_poem_request
    when started
    reads
      pattern:started
    writes
      schema:FrenchPoemRequest
    body_hash 073c55ea1b4838d7
  rule write_french_poem
    when FrenchPoemRequest as request where request.status == "queued"
    when codex is available
    reads
      pattern:codex is available
      schema:FrenchPoemRequest
    writes
      schema:FrenchPoemDraft
    consumes
      schema:FrenchPoemRequest
    effects
      poemTurn kind=agent.tell binding=poemTurn key=c78540c94fd343b8
    body_hash c7d249f29c57d300
  rule judge_french_poem
    when FrenchPoemDraft as draft where draft.status == "written"
    when codex is available
    reads
      pattern:codex is available
      schema:FrenchPoemDraft
    writes
      schema:FrenchPoemJudgment
    consumes
      schema:FrenchPoemDraft
    effects
      judgmentTurn kind=agent.tell binding=judgmentTurn key=27f996b85e2a9fe2
    body_hash 078fdbaf5cdad969
rule_dependencies
  seed_poem_request --schema:FrenchPoemRequest--> write_french_poem
  write_french_poem --schema:FrenchPoemDraft--> judge_french_poem
