workflow CodexPoemCoerceReview

use skill "baml-coerce-user"

class PoemRequest {
  topic string
  poemPath string
  status "queued"
}

class FrenchPoemReview {
  isFrench bool
  isPoem bool
  reason string
  confidence float
}

class ReviewedPoem {
  topic string
  poemPath string
  turn AgentTurn
  review FrenchPoemReview
  status "reviewed"
}

coerce reviewFrenchPoem(topic string, poemPath string, turnSummary string) -> FrenchPoemReview {
  prompt """
  Review the completed Codex poem turn.

  Topic:
  {{ topic }}

  Poem path:
  {{ poemPath }}

  Codex turn summary:
  {{ turnSummary }}

  Decide whether the generated artifact is in French and whether it is genuinely a poem.
  Return a typed review.

  {{ ctx.output_format }}
  """
}

agent codex {
  profile "repo-writer"
  capacity 1
}

assert none(PoemRequest where status == "queued")
assert one(ReviewedPoem where status == "reviewed")
assert one(effect kind agent.tell where status == completed)
assert one(effect kind baml.coerce where status == completed)

rule seed_poem_request
  when started
=> {
  record PoemRequest {
    topic "rain over a city at night"
    poemPath "target/dogfood/coerce-french-poem.txt"
    status "queued"
  }
}

rule write_and_review_poem
  when PoemRequest as request where request.status == "queued"
  when codex is available
=> {
  tell codex as poemTurn """
  Write an original poem in French.

  Requirements:
  - Use 8 to 12 verse lines.
  - Do not include an explanation or translation.
  - Use the theme: {{ request.topic }}.
  - Write only the poem text to {{ request.poemPath }}.
  - Do not edit files outside target/dogfood.

  Finish your turn with a concise summary that includes the poem path.
  """

  then coerce reviewFrenchPoem(request.topic, request.poemPath, poemTurn.summary) as review

  then done request -> record ReviewedPoem from request {
    topic
    poemPath
    turn poemTurn
    review review
    status "reviewed"
  }
}
