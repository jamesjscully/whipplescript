# Least-privilege child workflow composition. The parent delegates only the
# file-store paths the child needs, and the owned child turn repeats the same
# scoped grant for its in-turn file tools. Check with `--root ParentReview`.
class ReviewTask {
  id string
}

class ReviewSummary {
  note string
}

file store project_files {
  root "."
  allow read ["docs/**"]
  allow write ["reports/**"]
}

workflow ParentReview {
  input task ReviewTask
  output result ReviewSummary

  rule delegate
    when ReviewTask as task
  => {
    invoke ReviewDocs {
      task task
    }
      with access to project_files {
        read ["docs/**"]
        write ["reports/**"]
      }
      as review

    after review succeeds as summary {
      complete result {
        note summary.note
      }
    }
  }
}

workflow ReviewDocs {
  input task ReviewTask
  output result ReviewSummary

  agent reviewer {
    provider owned
    profile "repo-writer"
    capacity 1
  }

  rule review
    when ReviewTask as task
    when reviewer is available
  => {
    tell reviewer as turn
      with access to project_files {
        read ["docs/**"]
        write ["reports/**"]
      }
    """markdown
    Review docs for {{ task.id }} and update reports/review.md.
    """

    after turn succeeds {
      complete result {
        note turn.summary
      }
    }
  }
}
