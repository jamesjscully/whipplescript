{
  "contractVersion": 1,
  "scope": {
    "type": "repo",
    "id": "large-project"
  },
  "controlPlane": {
    "protectedDir": "builder_only",
    "agentVisibleSummary": "builder_only/orchestration/agent-contract-summary.md"
  },
  "state": {
    "authoritativeFiles": [
      "state/implementation-plan.json"
    ],
    "specRoots": [
      "specs/**"
    ],
    "artifactPaths": [
      "artifacts/**"
    ],
    "humanReviewQueue": ".beans/"
  },
  "sandbox": {
    "profile": "managed-agent",
    "read": {
      "allow": [
        "**"
      ],
      "deny": [
        ".git/**",
        "builder_only/**"
      ]
    },
    "write": {
      "allow": [
        "src/**",
        "tests/**",
        "docs/**",
        "artifacts/**",
        "state/implementation-plan.json"
      ],
      "deny": [
        ".git/**",
        "builder_only/**",
        "contracts/**"
      ]
    },
    "execute": {
      "enabled": true,
      "timeoutSeconds": 180,
      "allowedCommands": [
        "npm test",
        "npm run typecheck",
        "npm run build",
        "cargo test",
        "cargo clippy"
      ]
    },
    "network": {
      "mode": "deny-by-default",
      "allow": []
    },
    "egress": {
      "mode": "balanced",
      "allow": [
        "artifacts/**",
        "state/implementation-plan.json"
      ]
    }
  },
  "capabilities": {
    "supervisor": [
      "runtime.overview",
      "runtime.runs",
      "state.read",
      "director.message",
      "log.write"
    ],
    "director": [
      "state.read",
      "state.patch",
      "lease.acquire",
      "lease.release",
      "thread.start",
      "thread.status",
      "thread.result",
      "thread.interrupt",
      "beans.create",
      "log.write"
    ],
    "worker": [
      "state.read",
      "state.patchOwnedItem",
      "artifact.write",
      "tests.runAllowed",
      "log.write"
    ],
    "qualityGate": [
      "state.read",
      "artifact.read",
      "tests.runAllowed",
      "beans.create",
      "log.write"
    ]
  },
  "lifecycle": {
    "heartbeatEvery": "2m",
    "staleAfter": "10m",
    "retryLimit": 2,
    "maxActiveThreads": 4,
    "maxActivePerArea": 2
  },
  "completion": {
    "requiresPatch": true,
    "requiresTests": true,
    "requiresQualityGate": true,
    "onQualityFail": "human_review",
    "onRetryExhausted": "human_review"
  }
}
