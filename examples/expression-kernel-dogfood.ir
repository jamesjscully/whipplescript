workflow ExpressionKernelDogfood
schemas
  class KernelOwner
    name string
  class KernelTask
    provider agentref<codex | claude | pi>
    title string
    status union<literal<"queued"> | literal<"blocked"> | literal<"done">>
    route string
    tags array<string>
    metadata map<string>
    owner optional<ref<KernelOwner>>
    attempts int
    priority int
  class KernelRoute
    provider string
    title string
    route string
    tags array<string>
    metadata map<string>
    owner optional<ref<KernelOwner>>
    priority int
    status literal<"routed">
agents
  agent codex profile=repo-writer capacity=1 skills=[] capabilities=[]
  agent claude profile=repo-writer capacity=1 skills=[] capabilities=[]
  agent pi profile=repo-reader capacity=1 skills=[] capabilities=[]
assertions
  assert count(KernelTask where status == "queued") == 0
    reads
      fact:KernelTask where status == "queued"
  assert count(KernelRoute where provider in ["codex", "claude", "pi"]) == 3
    reads
      fact:KernelRoute where provider in ["codex", "claude", "pi"]
  assert exists(KernelRoute where (route == "docs") && ("expression-kernel" in tags))
    reads
      fact:KernelRoute where (route == "docs") && ("expression-kernel" in tags)
  assert empty(KernelRoute where priority > 9)
    reads
      fact:KernelRoute where priority > 9
  assert count(KernelRoute where ("phase" in metadata) && (metadata["phase"] == "kernel")) >= 1
    reads
      fact:KernelRoute where ("phase" in metadata) && (metadata["phase"] == "kernel")
  assert count(effect kind agent.tell where status == completed) == 3
    reads
      effect:kind agent.tell where status == completed
rules
  rule seed_expression_kernel_tasks
    when started
    reads
      pattern:started
    writes
      schema:KernelTask
    body_hash 60b0b5e1113e9cb8
  rule route_expression_kernel_task
    when KernelTask as task where ((((((task.status == "queued") && (task.route in ["code", "review", "docs"])) && ("expression-kernel" in task.tags)) && ("phase" in task.metadata)) && (task.metadata["phase"] == "kernel")) && ((task.owner == null) || exists(task.owner))) && !(task.priority > 5)
    when task.provider is available
    reads
      pattern:task.provider is available
      schema:KernelTask
    writes
      schema:KernelRoute
    consumes
      schema:KernelTask
    effects
      turn kind=agent.tell binding=turn key=8b0505583760d0ec
    body_hash 37e911aa39d2916c
  rule route_owned_expression_kernel_task
    when KernelTask as task where (((task.status == "queued") && exists(task.owner)) && (task.owner.name == "Ada")) && (task.metadata["phase"] not in ["deferred", "blocked"])
    when task.provider is available
    reads
      pattern:task.provider is available
      schema:KernelTask
    effects
      effect1 kind=agent.tell binding=- key=564d1660c459070d
    body_hash 32bbfb2ddb9100b3
  rule notice_routed_codex_task
    when KernelRoute as route where (route.provider == "codex") && exists(KernelRoute where provider == "codex")
    reads
      schema:KernelRoute
    projection_reads
      fact:KernelRoute where provider == "codex"
    body_hash cbf29ce484222325
rule_dependencies
  route_expression_kernel_task --schema:KernelRoute--> notice_routed_codex_task
  seed_expression_kernel_tasks --schema:KernelTask--> route_expression_kernel_task
  seed_expression_kernel_tasks --schema:KernelTask--> route_owned_expression_kernel_task
