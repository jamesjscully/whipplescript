workflow MultiProviderPoemReview

use skill "baml-coerce-user"

class PoemTask {
  poet AgentRef<codex | claude | pi>
  language string
  topic string
  expectedLineCount int
  artifactPath string
  status "queued"
}

class PoemQualityReview {
  isTargetLanguage bool
  isPoem bool
  matchesTopic bool
  hasExpectedLineCount bool
  reason string
  confidence float
}

class ReviewedPoem {
  provider string
  language string
  topic string
  artifactPath string
  turn AgentTurn
  review PoemQualityReview
  status "reviewed"
}

coerce reviewPoem(language string, topic string, expectedLineCount int, artifactPath string, turnSummary string) -> PoemQualityReview {
  prompt """
  Review the completed poem-writing task.

  Target language:
  {{ language }}

  Topic:
  {{ topic }}

  Expected line count:
  {{ expectedLineCount }}

  Artifact path:
  {{ artifactPath }}

  Provider turn summary:
  {{ turnSummary }}

  Decide whether the artifact is in the requested language, is genuinely a poem,
  matches the topic, and appears to have the requested line count.

  {{ ctx.output_format }}
  """
}

agent codex {
  profile "repo-writer"
  capacity 1
  capabilities ["agent.tell"]
}

agent claude {
  profile "repo-writer"
  capacity 1
  capabilities ["agent.tell"]
}

agent pi {
  profile "repo-writer"
  capacity 1
  capabilities ["agent.tell"]
}

assert count(PoemTask where status == "queued") == 3
assert count(ReviewedPoem where provider == "codex") == 1
assert count(ReviewedPoem where provider == "claude") == 1
assert count(ReviewedPoem where provider == "pi") == 1
assert count(ReviewedPoem where status == "reviewed") == 3
assert count(ReviewedPoem where review.confidence >= 0.5) == 3
assert count(effect kind agent.tell where status == completed) == 3
assert count(effect kind baml.coerce where status == completed) == 3

rule seed_poem_tasks
  when started
=> {
  record PoemTask {
    poet codex
    language "French"
    topic "rain over a city at night"
    expectedLineCount 6
    artifactPath "target/dogfood/poems/codex-french.txt"
    status "queued"
  }

  record PoemTask {
    poet claude
    language "Spanish"
    topic "a harbor at dawn"
    expectedLineCount 6
    artifactPath "target/dogfood/poems/claude-spanish.txt"
    status "queued"
  }

  record PoemTask {
    poet pi
    language "Japanese"
    topic "a quiet train station after rain"
    expectedLineCount 6
    artifactPath "target/dogfood/poems/pi-japanese.txt"
    status "queued"
  }
}

rule write_and_review_poem
  when PoemTask as task where task.status == "queued"
  when task.poet is available
=> {
  tell task.poet requires ["agent.tell"] as poemTurn """
  Write an original poem.

  Language:
  {{ task.language }}

  Topic:
  {{ task.topic }}

  Requirements:
  - Write exactly {{ task.expectedLineCount }} verse lines.
  - Write only the poem text, with no explanation or translation.
  - Save the poem to {{ task.artifactPath }}.
  - Do not edit files outside target/dogfood/poems.

  Finish your turn with a concise summary that includes the artifact path.
  """

  after poemTurn succeeds {
    coerce reviewPoem(task.language, task.topic, task.expectedLineCount, task.artifactPath, poemTurn.summary) as review
  }

  after review succeeds {
    record ReviewedPoem {
      provider task.poet
      language task.language
      topic task.topic
      artifactPath task.artifactPath
      turn poemTurn
      review review
      status "reviewed"
    }
  }
}
