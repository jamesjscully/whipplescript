workflow CompanionSkillDogfood
schemas
  class CompanionReviewTask
    reviewer agentref<codex | claude | pi>
    phase int
    title string
    trackerPath string
    route union<literal<"spec"> | literal<"validation"> | literal<"docs">>
    status literal<"queued">
  class CompanionReviewDispatch
    provider string
    phase int
    route string
    trackerPath string
    turn ref<AgentTurn>
    status literal<"dispatched">
agents
  agent codex profile=repo-reader capacity=1 skills=[] capabilities=[agent.tell]
  agent claude profile=repo-reader capacity=1 skills=[] capabilities=[agent.tell]
  agent pi profile=repo-reader capacity=1 skills=[] capabilities=[agent.tell]
assertions
  assert count(CompanionReviewTask where status == "queued") == 0
    reads
      fact:CompanionReviewTask where status == "queued"
  assert count(CompanionReviewDispatch where provider == "codex") == 1
    reads
      fact:CompanionReviewDispatch where provider == "codex"
  assert count(CompanionReviewDispatch where provider == "claude") == 1
    reads
      fact:CompanionReviewDispatch where provider == "claude"
  assert count(CompanionReviewDispatch where provider == "pi") == 1
    reads
      fact:CompanionReviewDispatch where provider == "pi"
  assert count(CompanionReviewDispatch where route in ["spec", "validation", "docs"]) == 3
    reads
      fact:CompanionReviewDispatch where route in ["spec", "validation", "docs"]
  assert count(effect kind agent.tell where status == completed) == 3
    reads
      effect:kind agent.tell where status == completed
rules
  rule seed_companion_review_matrix
    when started
    reads
      pattern:started
    writes
      schema:CompanionReviewTask
    body_hash dab7820e8619068d
  rule dispatch_companion_review
    when CompanionReviewTask as task where (task.status == "queued") && (task.route in ["spec", "validation", "docs"])
    when task.reviewer is available
    reads
      pattern:task.reviewer is available
      schema:CompanionReviewTask
    writes
      schema:CompanionReviewDispatch
    consumes
      schema:CompanionReviewTask
    effects
      turn kind=agent.tell binding=turn key=ba85edd93a4a1658
    body_hash 52338ae869c77fab
rule_dependencies
  seed_companion_review_matrix --schema:CompanionReviewTask--> dispatch_companion_review
