workflow CodexClaudeHarnessReview
schemas
  class ImplementationTask
    title string
    body string
    status literal<"queued">
  class ReviewedImplementation
    title string
    implementation ref<AgentTurn>
    review ref<AgentTurn>
    status literal<"reviewed">
harnesses
  harness coder kind=codex
  harness reviewerHarness kind=claude
agents
  agent implementer harness=coder profile=repo-writer capacity=1 skills=[] capabilities=[agent.tell]
  agent reviewer harness=reviewerHarness profile=repo-reader capacity=1 skills=[] capabilities=[agent.tell]
assertions
  assert none(ImplementationTask where status == "queued")
    reads
      fact:ImplementationTask where status == "queued"
  assert one(ReviewedImplementation where status == "reviewed")
    reads
      fact:ReviewedImplementation where status == "reviewed"
  assert count(effect kind agent.tell where status == completed) == 2
    reads
      effect:kind agent.tell where status == completed
rules
  rule seed_task
    when started
    reads
      pattern:started
    writes
      schema:ImplementationTask
    body_hash 89c49c055a69e21c
  rule implement_then_review
    when ImplementationTask as task where task.status == "queued"
    when implementer is available
    reads
      pattern:implementer is available
      schema:ImplementationTask
    writes
      schema:ReviewedImplementation
    consumes
      schema:ImplementationTask
    effects
      implementation kind=agent.tell binding=implementation key=3098597a636e0dac
      review kind=agent.tell binding=review key=820b1d93d53ca5fc
    dependencies
      implementation --succeeds--> review
    body_hash 4c4dbd704d93eb7e
rule_dependencies
  seed_task --schema:ImplementationTask--> implement_then_review
