use std.agent

@service
workflow Ralph

agent ralph {
  provider fixture
  profile "repo-writer"
  capacity 1
}

rule begin
  when started
  when ralph is available
=> {
  tell ralph "Do one small useful thing and update the todo list."
}

rule again
  when ralph completed turn
  when ralph is available
=> {
  tell ralph "Do one small useful thing and update the todo list."
}
