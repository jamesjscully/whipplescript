load ../kernel.maude
load ../construct-grammar.maude
load ../construct-graph.maude
load ../construct-lowering.maude

--- An accepted construct edge is preserved when lowering emits a corresponding
--- core relation and keeps type, resource, capability, version, span,
--- cardinality, and provenance.
search [1] in WHIPPLESCRIPT-CONSTRUCT-LOWERING :
  edgeAccepted(memoryNode, reqIssue, projectionNode, provIssue)
  coreRelationForEdge(memoryNode, reqIssue, projectionNode, provIssue)
  edgeTypePreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeResourcePreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeCapabilityPreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeVersionPreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeSpanPreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeCardinalityPreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeProvenancePreserved(memoryNode, reqIssue, projectionNode, provIssue)
  =>*
  C:Cfg
  edgeLoweringPreserved(memoryNode, reqIssue, projectionNode, provIssue) .

--- A graph lowers only when the accepted-program boundary holds and every node
--- and required edge preserves its contract into ordinary core IR.
