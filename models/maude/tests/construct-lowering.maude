  nodeClassLifecycleAccepted(projectionNode)
  nodeClassOutputAccepted(projectionNode, projectionViewLowering)
  nodeAccepted(g1, memoryNode)
  nodeNeeds1(memoryNode, reqIssue)
  edgeAccepted(memoryNode, reqIssue, projectionNode, provIssue)
  coreRelationForEdge(memoryNode, reqIssue, projectionNode, provIssue)
  edgeTypePreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeResourcePreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeCapabilityPreserved(memoryNode, reqIssue, projectionNode, provIssue)
  edgeVersionPreserved(memoryNode, reqIssue, projectionNode, provIssue)
