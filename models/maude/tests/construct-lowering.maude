  allowedCoreObjectKind(coreEffectKind)
  allowedCoreObjectKind(coreDependencyKind)
  coreObjectOwnedByNode(g1, coreFactObj, projectionNode)
  coreObjectOwnedByNode(g1, coreEffectObj, memoryNode)
  coreObjectOwnedByEdge(g1, coreDependencyObj, memoryNode, reqIssue, projectionNode, provIssue)
  coreObjectOwnerUnique(g1, coreFactObj)
  coreObjectOwnerUnique(g1, coreEffectObj)
  coreObjectOwnerUnique(g1, coreDependencyObj)
  noRuntimeInputsDuringLowering(g1)
  =>*
  C:Cfg
  loweringPreserved(g1) .

--- Generated lowered-IR facts can account for multiple core objects owned by
