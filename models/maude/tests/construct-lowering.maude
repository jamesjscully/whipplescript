  nodeCardinalityPreserved(memoryNode)
  nodeProvenancePreserved(memoryNode)
  terminalBindingPreserved(memoryNode)
  nodeClassLifecycleAccepted(memoryNode)
  nodeClassOutputAccepted(memoryNode, capabilityCall)
  loweringDeterministic(g1)
  loweredIrReportComplete(g1)
  graphEmits3(g1, coreFactObj, coreEffectObj, coreDependencyObj)
  nodeCoreObjects1(projectionNode, coreFactObj)
  nodeCoreObjects1(memoryNode, coreEffectObj)
  edgeCoreObjects1(memoryNode, reqIssue, projectionNode, provIssue, coreDependencyObj)
  emittedCoreObject(g1, coreFactObj, coreFactKind)
  emittedCoreObject(g1, coreEffectObj, coreEffectKind)
  emittedCoreObject(g1, coreDependencyObj, coreDependencyKind)
