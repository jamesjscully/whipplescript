  graphContainsNode(g1, memoryNode)
  edgeAccepted(memoryNode, reqIssue, projectionNode, provIssue)
  edgeCoreObjects(memoryNode, reqIssue, projectionNode, provIssue, coreObjectCons(coreDependencyObj, coreObjectCons(coreProjectionObj, noCoreObjects)))
  emittedCoreObject(g1, coreDependencyObj, coreDependencyKind)
  emittedCoreObject(g1, coreProjectionObj, coreProjectionKind)
  allowedCoreObjectKind(coreDependencyKind)
  allowedCoreObjectKind(coreProjectionKind)
  coreObjectOwnedByEdge(g1, coreDependencyObj, memoryNode, reqIssue, projectionNode, provIssue)
  coreObjectOwnedByEdge(g1, coreProjectionObj, memoryNode, reqIssue, projectionNode, provIssue)
  coreObjectOwnerUnique(g1, coreDependencyObj)
  coreObjectOwnerUnique(g1, coreProjectionObj)
  noRuntimeInputsDuringLowering(g1)
  =>*
  C:Cfg
  graphLoweringBoundaryOk(g1) .

