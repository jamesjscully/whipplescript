load ../kernel.maude
load ../construct-grammar.maude
load ../construct-graph.maude

--- A graph with a provider node and a consumer node is accepted when the
--- required port resolves through one compatible, versioned, resource-scoped
--- edge and the consumer's capability/lowering obligations are closed.
search [1] in WHIPPLESCRIPT-CONSTRUCT-GRAPH :
  graphNodes2(g1, projectionNode, memoryNode)
  graphContainsNode(g1, projectionNode)
  graphContainsNode(g1, memoryNode)
  nodeFamilyAccepted(projectionNode)
  nodeLoweringAccepted(projectionNode)
  nodeShapeUnique(projectionNode)
  noHiddenNodeBehavior(projectionNode)
  nodeFactsConsistent(projectionNode)
  nodeNeeds0(projectionNode)
  nodeProduces1(projectionNode, provIssue)
  noCapabilityRequirements(projectionNode)
  loweringOutput(projectionNode, coreFactOut)
  allowedLoweringOutput(coreFactOut)
  singleLoweringOutput(projectionNode)
  providesPort(projectionNode, provIssue)
  producedPortAllowed(projectionNode, provIssue)
  nodeFamilyAccepted(memoryNode)
  nodeLoweringAccepted(memoryNode)
  nodeShapeUnique(memoryNode)
  noHiddenNodeBehavior(memoryNode)
  nodeFactsConsistent(memoryNode)
  nodeNeeds1(memoryNode, reqIssue)
  nodeProduces0(memoryNode)
  nodeRequiresCapability(memoryNode, memoryQuery)
  declaredCapability(memoryQuery)
  loweredEffectRequiresCapability(memoryNode, e1, memoryQuery)
  loweringOutput(memoryNode, coreEffectOut)
  allowedLoweringOutput(coreEffectOut)
  singleLoweringOutput(memoryNode)
  resolvesPort(memoryNode, reqIssue, projectionNode, provIssue)
  uniqueResolution(memoryNode, reqIssue)
  uniqueResolvedPort(memoryNode, reqIssue, projectionNode, provIssue)
  resolutionFactsConsistent(memoryNode, reqIssue)
  port(reqIssue, valueKind, issueType, compilePhase, v1, exactlyOne)
  port(provIssue, valueKind, issueType, compilePhase, v1, exactlyOne)
  kindCompatible(valueKind, valueKind)
  typeAssignable(issueType, issueType)
  phaseCompatible(compilePhase, compilePhase)
  versionCompatible(v1, v1)
  resourceCompatible(reqIssue, provIssue)
  =>*
  C:Cfg
  graphAccepted(g1) .

--- A node with no required ports can be accepted when its authority and
--- lowering obligations are still explicit.
search [1] in WHIPPLESCRIPT-CONSTRUCT-GRAPH :
  graphNodes1(g1, scheduleNode)
  graphContainsNode(g1, scheduleNode)
  nodeFamilyAccepted(scheduleNode)
  nodeLoweringAccepted(scheduleNode)
  nodeShapeUnique(scheduleNode)
  noHiddenNodeBehavior(scheduleNode)
  nodeFactsConsistent(scheduleNode)
  nodeNeeds0(scheduleNode)
  nodeProduces0(scheduleNode)
  noCapabilityRequirements(scheduleNode)
  loweringOutput(scheduleNode, coreEventOut)
  allowedLoweringOutput(coreEventOut)
  singleLoweringOutput(scheduleNode)
  =>*
  C:Cfg
  graphAccepted(g1) .

