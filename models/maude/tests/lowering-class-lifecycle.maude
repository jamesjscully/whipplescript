  classOutputBoundaryValidated(typedEffectCall)
  classAllowsOutput(typedEffectCall, coreEffectKind, effectGraphTemplate)
  classCoreOutputs1(typedEffectCall, coreEffectKind, effectGraphTemplate)
  entrypointMatchesObjectKind(coreEffectKind, effectGraphTemplate)
  =>*
  Rest:Cfg
  loweringClassLifecycleOk(typedEffectCall)
  objectEntrypointAccepted(typedEffectCall, coreEffectKind, effectGraphTemplate) .

--- Generated lifecycle facts can accept and project more node-owned outputs
--- than the small hand-written arity-specific rules model directly.
search [1] in WHIPPLESCRIPT-LOWERING-CLASS-LIFECYCLE :
  classRegistered(typedEffectCall)
  classAllowsFamily(typedEffectCall, effectOperation)
  classDeterministic(typedEffectCall)
  classContractPinned(typedEffectCall)
  classNoRuntimeInputs(typedEffectCall)
  classNoHiddenAuthority(typedEffectCall)
  classNoPackageScheduler(typedEffectCall)
  classNoPackageLifecycle(typedEffectCall)
  classNoDirectFactWrite(typedEffectCall)
  classNoDirectRuleFire(typedEffectCall)
  classCapabilityScoped(typedEffectCall)
  classOutputBoundaryValidated(typedEffectCall)
  classAllowsOutput(typedEffectCall, coreEffectKind, effectGraphTemplate)
  classAllowsOutput(typedEffectCall, coreRuleKind, ruleTemplate)
  classAllowsOutput(typedEffectCall, coreAssertionKind, assertionCheck)
  classCoreOutputs(typedEffectCall, classOutputCons(coreEffectKind, effectGraphTemplate, classOutputCons(coreRuleKind, ruleTemplate, classOutputCons(coreAssertionKind, assertionCheck, noClassOutputs))))
  entrypointMatchesObjectKind(coreEffectKind, effectGraphTemplate)
  entrypointMatchesObjectKind(coreRuleKind, ruleTemplate)
  entrypointMatchesObjectKind(coreAssertionKind, assertionCheck)
  nodeUsesLoweringClass(memoryNode, typedEffectCall)
  nodeConstructFamily(memoryNode, effectOperation)
  nodeClassOutput(memoryNode, typedEffectCall, nodeClassOutputCons(coreEffectObj, coreEffectKind, effectGraphTemplate, nodeClassOutputCons(coreRuleObj, coreRuleKind, ruleTemplate, nodeClassOutputCons(coreAssertionObj, coreAssertionKind, assertionCheck, noNodeClassOutputs))))
  =>*
  Rest:Cfg
  loweringClassLifecycleOk(typedEffectCall)
  nodeClassLifecycleAccepted(memoryNode)
  nodeClassOutputAccepted(memoryNode, typedEffectCall)
  nodeCoreObjects(memoryNode, coreObjectCons(coreAssertionObj, coreObjectCons(coreRuleObj, coreObjectCons(coreEffectObj, noCoreObjects))))
  objectEntrypointAccepted(typedEffectCall, coreEffectKind, effectGraphTemplate)
  objectEntrypointAccepted(typedEffectCall, coreRuleKind, ruleTemplate)
  objectEntrypointAccepted(typedEffectCall, coreAssertionKind, assertionCheck) .

--- Unknown lowering classes are inert unless the platform registers a complete
