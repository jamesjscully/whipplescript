  classNoPackageLifecycle(unknownLowering)
  classNoDirectFactWrite(unknownLowering)
  classNoDirectRuleFire(unknownLowering)
  classNoAuthorityNeeded(unknownLowering)
  classAllowsNoOutput(unknownLowering)
  classCoreOutputs0(unknownLowering)
  =>*
  Rest:Cfg
  loweringClassLifecycleOk(unknownLowering) .

