load ../kernel.maude
load ../construct-grammar.maude
load ../construct-graph.maude
load ../construct-lowering.maude
load ../lowering-runtime-handoff.maude
load ../lowering-class-lifecycle.maude

--- Metadata lowering is accepted only as a no-output, no-authority class.
search [1] in WHIPPLESCRIPT-LOWERING-CLASS-LIFECYCLE :
  classRegistered(metadataLowering)
  classAllowsFamily(metadataLowering, declarationBlock)
  classDeterministic(metadataLowering)
  classContractPinned(metadataLowering)
  classNoRuntimeInputs(metadataLowering)
  classNoHiddenAuthority(metadataLowering)
  classNoPackageScheduler(metadataLowering)
  classNoPackageLifecycle(metadataLowering)
  classNoDirectFactWrite(metadataLowering)
  classNoDirectRuleFire(metadataLowering)
  classNoAuthorityNeeded(metadataLowering)
  classAllowsNoOutput(metadataLowering)
  classCoreOutputs0(metadataLowering)
  nodeUsesLoweringClass(projectionNode, metadataLowering)
  nodeConstructFamily(projectionNode, declarationBlock)
  nodeClassOutput0(projectionNode, metadataLowering)
  =>*
  Rest:Cfg
  loweringClassLifecycleOk(metadataLowering)
  nodeClassLifecycleAccepted(projectionNode)
  nodeClassOutputAccepted(projectionNode, metadataLowering)
  nodeCoreObjects0(projectionNode) .

--- capability_call lowers effect operations to effect graph templates with
--- capability-scoped authority and runtime-boundary output validation.
search [1] in WHIPPLESCRIPT-LOWERING-CLASS-LIFECYCLE :
  classRegistered(capabilityCall)
  classAllowsFamily(capabilityCall, effectOperation)
  classDeterministic(capabilityCall)
  classContractPinned(capabilityCall)
  classNoRuntimeInputs(capabilityCall)
  classNoHiddenAuthority(capabilityCall)
  classNoPackageScheduler(capabilityCall)
  classNoPackageLifecycle(capabilityCall)
  classNoDirectFactWrite(capabilityCall)
  classNoDirectRuleFire(capabilityCall)
  classCapabilityScoped(capabilityCall)
  classOutputBoundaryValidated(capabilityCall)
  classAllowsOutput(capabilityCall, coreEffectKind, effectGraphTemplate)
  classCoreOutputs1(capabilityCall, coreEffectKind, effectGraphTemplate)
  entrypointMatchesObjectKind(coreEffectKind, effectGraphTemplate)
  nodeUsesLoweringClass(memoryNode, capabilityCall)
  nodeConstructFamily(memoryNode, effectOperation)
  nodeClassOutput1(memoryNode, capabilityCall, coreEffectObj, coreEffectKind, effectGraphTemplate)
  =>*
  Rest:Cfg
  loweringClassLifecycleOk(capabilityCall)
  nodeClassLifecycleAccepted(memoryNode)
  nodeClassOutputAccepted(memoryNode, capabilityCall)
  nodeCoreObjects1(memoryNode, coreEffectObj)
  allowedCoreObjectKind(coreEffectKind)
  objectEntrypointAccepted(capabilityCall, coreEffectKind, effectGraphTemplate) .

