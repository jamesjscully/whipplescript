  eq geExpr(Ex, exprError) = exprError .
  eq inExpr(Ex, arrayHas(Ex)) = boolTrue .
  eq inExpr(Ex, arrayMissing(Ex)) = boolFalse .
  eq inExpr(Ex, arrayOf(EL)) = inList(Ex, EL) .
  eq inList(Ex, exprNil) = boolFalse .
  eq inList(Ex, exprCons(Ex, EL)) = boolTrue .
  eq inList(Ex, exprCons(Ex1, EL)) = inList(Ex, EL) [owise] .
  eq inExpr(Ex, mapHas(Ex, Ex1)) = boolTrue .
  eq inExpr(Ex, mapMissing(Ex)) = boolFalse .
  eq inExpr(Ex, mapOf(KL)) = inEntryKeys(Ex, KL) .
  eq inExpr(Ex, objectHas(Ex, Ex1)) = boolTrue .
  eq inExpr(Ex, objectMissing(Ex)) = boolFalse .
  eq inExpr(Ex, objectOf(KL)) = inEntryKeys(Ex, KL) .
  eq inEntryKeys(Ex, entryNil) = boolFalse .
  eq inEntryKeys(Ex, entryCons(entry(Ex, Ex1), KL)) = boolTrue .
  eq inEntryKeys(Ex, entryCons(entry(Ex1, Ex2), KL)) = inEntryKeys(Ex, KL) [owise] .
  eq inExpr(Ex, arrayEmpty) = boolFalse .
  eq inExpr(Ex, mapEmpty) = boolFalse .
  eq inExpr(Ex, objectEmpty) = boolFalse .
  eq inExpr(exprError, Ex) = exprError .
  eq inExpr(Ex, exprError) = exprError .
  eq indexExpr(mapHas(Ex1, Ex2), Ex1) = Ex2 .
  eq indexExpr(mapMissing(Ex1), Ex1) = exprError .
  eq indexExpr(mapOf(KL), Ex) = indexEntries(Ex, KL) .
  eq indexExpr(objectHas(Ex1, Ex2), Ex1) = Ex2 .
  eq indexExpr(objectMissing(Ex1), Ex1) = exprError .
  eq indexExpr(objectOf(KL), Ex) = indexEntries(Ex, KL) .
  eq indexEntries(Ex, entryNil) = exprError .
  eq indexEntries(Ex, entryCons(entry(Ex, Ex1), KL)) = Ex1 .
  eq indexEntries(Ex, entryCons(entry(Ex1, Ex2), KL)) = indexEntries(Ex, KL) [owise] .
  eq indexExpr(exprError, Ex) = exprError .
  eq indexExpr(Ex, exprError) = exprError .
  eq evalGuard(boolTrue) = gTrue .
  eq evalGuard(boolFalse) = gFalse .
  eq evalGuard(exprError) = gError .
  eq evalAssertion(boolTrue) = aPass .
  eq evalAssertion(boolFalse) = aFail .
  eq evalAssertion(exprError) = aError .

  --- Event-log projection into typed facts.
  rl [derive-fact] :
    event(Ev) projection(Ev, F, pending)
    => event(Ev) projection(Ev, F, projected) fact(F) .

  --- Effect completion projection into typed lifecycle/domain facts.
  rl [derive-completion-fact] :
    effect(E, S) completionProjection(E, S, F, pending)
    => effect(E, S) completionProjection(E, S, F, projected) fact(F) .

  --- Pattern applications are compile-time source elaboration. The runtime
  --- kernel only sees the generated first-order rule plus provenance; no
  --- instance, event, or effect is created by applying a pattern.
  rl [elaborate-pattern] :
    patternApp(Pat, App, R, F, G)
    => patternElaborated(Pat, App, R, F, G) rule(R, F, G) ruleProvenance(R, Pat, App) .

  --- Rules are one-shot rewrites over facts. The graph is committed later by
  --- the kernel; provider execution never happens during rule firing.
  rl [guard-true-ready] :
    fact(F) rule(R, F, G) guard(R, F, gTrue)
    => fact(F) rule(R, F, G) ruleReady(R, F, G) .

  rl [guard-error-diagnostic] :
    fact(F) rule(R, F, G) guard(R, F, gError)
    => fact(F) rule(R, F, G) diagnostic(R) .

  crl [guard-expr-true-ready] :
    fact(F) rule(R, F, G) guardExpr(R, F, Ex)
    => fact(F) rule(R, F, G) ruleReady(R, F, G)
    if evalGuard(Ex) == gTrue .

  crl [guard-expr-error-diagnostic] :
    fact(F) rule(R, F, G) guardExpr(R, F, Ex)
    => fact(F) rule(R, F, G) diagnostic(R)
    if evalGuard(Ex) == gError .

  rl [domain-guard-true] :
    fact(F) domainGuard(R, F, V, Dm) domainMember(V, Dm)
    => fact(F) guard(R, F, gTrue) domainMember(V, Dm) .

  --- Typed finite-domain pattern branches are rule-readiness gates. A branch
  --- can fire only when the matched value belongs to the branch's enum/literal
  --- domain. Non-matching branches do not produce diagnostics by themselves.
  rl [pattern-branch-match] :
    fact(F) patternBranch(R, F, V, Dm, G) domainMember(V, Dm)
    => fact(F) ruleReady(R, F, G) domainMember(V, Dm) .

  --- Exhaustive matches over finite domains may produce a diagnostic when the
  --- value is outside every covered branch. This models compiler/runtime
  --- evidence for missing enum/literal cases without committing a graph.
  rl [exhaustive-pattern-miss] :
    fact(F) exhaustivePattern(R, F, V, Dm) domainNonMember(V, Dm)
    => fact(F) diagnostic(R) domainNonMember(V, Dm) .

  --- Optional/non-null pattern branches bind a proven-present value. The bound
  --- path can then be read without treating Missing as Null.
  rl [optional-some-branch] :
    fact(F) optionalSomeBranch(R, F, X, G) path(X, present)
    => fact(F) ruleReady(R, F, G) path(X, present) boundPresent(X) .

  rl [optional-none-branch] :
    fact(F) optionalNoneBranch(R, F, X, G) path(X, missing)
    => fact(F) ruleReady(R, F, G) path(X, missing) .

  --- Terminal-output union branches are finite-domain gates over effect
  --- terminal tags. The tag must match before the branch graph can commit; an
  --- optional branch guard is evaluated after tag refinement.
  rl [terminal-branch-match] :
    fact(F) terminalBranch(R, F, Tag, Tag, G)
    => fact(F) ruleReady(R, F, G) .

  crl [terminal-branch-guard-match] :
    fact(F) terminalBranchGuard(R, F, Tag, Tag, Ex, G)
    => fact(F) ruleReady(R, F, G)
    if evalGuard(Ex) == gTrue .

  crl [terminal-branch-guard-error] :
    fact(F) terminalBranchGuard(R, F, Tag, Tag, Ex, G)
    => fact(F) diagnostic(R)
    if evalGuard(Ex) == gError .

  rl [exhaustive-terminal-miss] :
    fact(F) exhaustiveTerminal(R, F, Tag, Tag2)
    => fact(F) diagnostic(R) .

  rl [fire-rule] :
    fact(F) rule(R, F, G) ruleReady(R, F, G)
    => fact(F) rule(R, F, G) ruleFired(R, F, G) graphReady(G) event(ruleCommitEvt) .

  --- Instance-scoped rules can fire only while their workflow instance is
  --- running. Terminal workflow instances do not commit additional effectful
  --- rewrites.
  rl [fire-scoped-rule] :
    instance(I, W, instRunning) fact(F) scopedRule(I, R, F, G) ruleReady(R, F, G)
    => instance(I, W, instRunning) fact(F) scopedRule(I, R, F, G)
       scopedRuleFired(I, R, F, G) graphReady(G) event(ruleCommitEvt) .

  --- Version-scoped rules can fire only when the instance is still on the
  --- active program version and revision epoch used during rule evaluation.
  --- After a revision activates, stale old-version rules have no matching
  --- activeRevision term and therefore cannot create new effects.
  rl [fire-versioned-scoped-rule] :
    instance(I, W, instRunning) activeRevision(I, PV, Ep)
    fact(F) scopedRuleV(I, PV, Ep, R, F, G) ruleReady(R, F, G)
    => instance(I, W, instRunning) activeRevision(I, PV, Ep)
       fact(F) scopedRuleV(I, PV, Ep, R, F, G)
       scopedRuleFired(I, R, F, G) graphReady(G) event(ruleCommitEvt) .

  --- Workflow completion is explicit and terminal. A `complete` or `fail`
  --- action must name a declared output/failure contract for the current
  --- workflow. The terminal payload is projected for parent invocation
  --- resolution without exposing child-local facts.
  rl [complete-workflow] :
    instance(I, W, instRunning) workflowOutput(W, O) completeWorkflow(I, O, F) fact(F)
    => instance(I, W, instCompleted) workflowOutput(W, O) terminalPayload(I, F)
       fact(F) event(workflowCompletedEvt) .

  rl [fail-workflow] :
    instance(I, W, instRunning) workflowFailure(W, Fail) failWorkflow(I, Fail, F) fact(F)
    => instance(I, W, instFailed) workflowFailure(W, Fail) terminalPayload(I, F)
       fact(F) event(workflowFailedEvt) .

  --- Assertions are read-only checks over projected state.
  rl [assertion-fail-diagnostic] :
    assertion(A, aFail)
    => assertionDiagnostic(A) .

  rl [assertion-error-diagnostic] :
    assertion(A, aError)
    => assertionDiagnostic(A) .

  crl [assertion-expr-fail-diagnostic] :
    assertionExpr(A, Ex)
    => assertionDiagnostic(A)
    if evalAssertion(Ex) == aFail .

  crl [assertion-expr-error-diagnostic] :
    assertionExpr(A, Ex)
    => assertionDiagnostic(A)
    if evalAssertion(Ex) == aError .

  --- Optional path reads are allowed only when presence is known.
  rl [read-present-path] :
    path(X, present) readPath(X)
    => path(X, present) readOk(X) .

  rl [read-bound-present-path] :
    boundPresent(X) readPath(X)
    => boundPresent(X) readOk(X) .

  --- Effect graph commits create durable outbox nodes and dependency edges.
  rl [commit-single-effect-graph] :
    graph(G, U) graphReady(G)
    => graphCommitted(G) effect(U, queued) .

  rl [commit-versioned-effect-graph] :
    graphV(G, PV, Ep, U) graphReady(G)
    => graphCommitted(G) effect(U, queued) effectVersion(U, PV, Ep) .

  rl [commit-dependent-effect-graph] :
    graph2(G, U, P, D) graphReady(G)
    => graphCommitted(G) effect(U, queued) dep(U, P, D) effect(D, blocked) .

  rl [commit-agent-effect-graph] :
    graphAgent(G, U, T) graphReady(G) declaredAgent(T)
    => graphCommitted(G) effect(U, queued) tellTarget(U, T) declaredAgent(T) .

  --- Invoking a workflow is runtime composition. It creates a child instance
  --- behind an invocation effect; it does not inline the child rules into the
  --- parent. The invocation effect resolves only when the child reaches an
  --- explicit terminal workflow event.
  rl [start-workflow-invocation] :
    effect(E, running) invokeWorkflow(E, I, W, CI)
    => effect(E, running) instance(CI, W, instRunning) childOf(CI, E) .

  rl [complete-workflow-invocation] :
    effect(E, running) childOf(CI, E) instance(CI, W, instCompleted) terminalPayload(CI, F)
    => effect(E, completed) childOf(CI, E) instance(CI, W, instCompleted)
       terminalPayload(CI, F) invocationOutput(E, F) .

  rl [fail-workflow-invocation] :
    effect(E, running) childOf(CI, E) instance(CI, W, instFailed) terminalPayload(CI, F)
    => effect(E, failed) childOf(CI, E) instance(CI, W, instFailed)
       terminalPayload(CI, F) invocationFailure(E, F) .

  rl [cancel-workflow-invocation] :
    effect(E, running) childOf(CI, E) instance(CI, W, instCancelled)
    => effect(E, cancelled) childOf(CI, E) instance(CI, W, instCancelled)
       invocationCancellation(E) .

  --- A queued effect can be claimed and then started by an external worker.
  rl [claim-effect] : effect(E, queued) => effect(E, claimed) .
  rl [start-run] : effect(E, claimed) => effect(E, running) .

  --- Terminal provider outcomes are recorded by the kernel from worker
  --- completion events. Invocation effects do not receive providerRun markers;
  --- they resolve only from child workflow terminal state above.
  rl [complete-run] : effect(E, running) providerRun(E) => effect(E, completed) providerRun(E) .
  rl [fail-run] : effect(E, running) providerRun(E) => effect(E, failed) providerRun(E) .
  rl [timeout-run] : effect(E, running) providerRun(E) => effect(E, timedOut) providerRun(E) .
  rl [recover-provider-terminal] :
    effect(E, running) providerRun(E) providerEvidence(E, S)
    => effect(E, S) providerRun(E) providerEvidence(E, S) .
  rl [required-artifact-capture-failure] :
    effect(E, running) providerRun(E) requiredArtifactCaptureFailure(E)
    => effect(E, failed) providerRun(E) requiredArtifactCaptureFailure(E) .

  --- Cancellation is available before an effect starts running.
  rl [cancel-queued] : effect(E, queued) => effect(E, cancelled) .
  rl [cancel-blocked] : effect(E, blocked) => effect(E, cancelled) .
  rl [cancel-claimed] : effect(E, claimed) => effect(E, cancelled) .

  --- Revision activation is an explicit control-plane transition, not a source
  --- rule. It advances the active revision for a running instance and records
  --- the policy that will later be applied to old-version effects.
  rl [activate-revision] :
    instance(I, W, instRunning) activeRevision(I, PV, Ep)
    nextEpoch(Ep, Ep2) activateRevision(I, PV, PV2, Ep, Ep2, CP)
    => instance(I, W, instRunning) activeRevision(I, PV2, Ep2)
       nextEpoch(Ep, Ep2)
       revisionActivated(I, PV, PV2, Ep2, CP)
       revisionCancellationPolicy(I, PV, Ep, CP)
       event(revisionActivatedEvt) .

  rl [revision-cancel-queued] :
    effect(E, queued) effectVersion(E, PV, Ep)
    revisionCancellationPolicy(I, PV, Ep, cancelQueued)
    => effect(E, cancelled) effectVersion(E, PV, Ep)
       revisionCancellationPolicy(I, PV, Ep, cancelQueued) .

  rl [revision-cancel-blocked] :
    effect(E, blocked) effectVersion(E, PV, Ep)
    revisionCancellationPolicy(I, PV, Ep, cancelQueued)
    => effect(E, cancelled) effectVersion(E, PV, Ep)
       revisionCancellationPolicy(I, PV, Ep, cancelQueued) .

  rl [revision-request-cancel-queued] :
    effect(E, queued) effectVersion(E, PV, Ep)
    revisionCancellationPolicy(I, PV, Ep, requestRunning)
    => effect(E, cancelled) effectVersion(E, PV, Ep)
       revisionCancellationPolicy(I, PV, Ep, requestRunning) .

  rl [revision-request-cancel-blocked] :
    effect(E, blocked) effectVersion(E, PV, Ep)
    revisionCancellationPolicy(I, PV, Ep, requestRunning)
    => effect(E, cancelled) effectVersion(E, PV, Ep)
       revisionCancellationPolicy(I, PV, Ep, requestRunning) .

  rl [revision-request-cancel-claimed] :
    effect(E, claimed) effectVersion(E, PV, Ep) requestable(E)
    revisionCancellationPolicy(I, PV, Ep, requestRunning)
    => effect(E, claimed) effectVersion(E, PV, Ep)
       revisionCancellationPolicy(I, PV, Ep, requestRunning)
       cancellationRequested(E) .

  rl [revision-request-cancel-running] :
    effect(E, running) effectVersion(E, PV, Ep) requestable(E)
    revisionCancellationPolicy(I, PV, Ep, requestRunning)
    => effect(E, running) effectVersion(E, PV, Ep)
       revisionCancellationPolicy(I, PV, Ep, requestRunning)
       cancellationRequested(E) .

  rl [acknowledge-running-cancellation] :
    effect(E, running) cancellationRequested(E)
    => effect(E, running) cancellationAcknowledged(E) .

  --- Policy and capacity are modeled separately from dependency blocking so
  --- status and diagnostics can explain why work did not start.
  rl [policy-release] :
    effect(E, blockedByPolicy) policyAllows(E)
    => effect(E, queued) policyAllows(E) .

  rl [capacity-release] :
    effect(E, blockedByCapacity) capacityAvailable(E)
    => effect(E, queued) capacityAvailable(E) .

  --- Lease expiry and retry reuse effect identity in this abstract model.
  rl [expire-lease] :
    effect(E, running) lease(E, leaseActive)
    => effect(E, queued) lease(E, leaseExpired) event(leaseExpiredEvt) .

  rl [retry-failed] :
    effect(E, failed) retryAllowed(E)
    => effect(E, queued) retryUsed(E) .

  rl [retry-timeout] :
    effect(E, timedOut) retryAllowed(E)
    => effect(E, queued) retryUsed(E) .

  --- Dependency release rules. Source order never releases an effect; only
  --- terminal upstream outcomes do.
  rl [unblock-success] :
    effect(U, completed) dep(U, succeeds, D) effect(D, blocked)
    => effect(U, completed) dep(U, succeeds, D) effect(D, queued) .

  rl [unblock-failure] :
    effect(U, failed) dep(U, fails, D) effect(D, blocked)
    => effect(U, failed) dep(U, fails, D) effect(D, queued) .

  rl [unblock-timeout-as-failure] :
    effect(U, timedOut) dep(U, fails, D) effect(D, blocked)
    => effect(U, timedOut) dep(U, fails, D) effect(D, queued) .

  rl [unblock-completes-ok] :
    effect(U, completed) dep(U, completes, D) effect(D, blocked)
    => effect(U, completed) dep(U, completes, D) effect(D, queued) .

  rl [unblock-completes-fail] :
    effect(U, failed) dep(U, completes, D) effect(D, blocked)
    => effect(U, failed) dep(U, completes, D) effect(D, queued) .

  rl [unblock-completes-timeout] :
    effect(U, timedOut) dep(U, completes, D) effect(D, blocked)
    => effect(U, timedOut) dep(U, completes, D) effect(D, queued) .

  rl [unblock-completes-cancelled] :
    effect(U, cancelled) dep(U, completes, D) effect(D, blocked)
    => effect(U, cancelled) dep(U, completes, D) effect(D, queued) .
endm
