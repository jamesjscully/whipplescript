  eq gtExpr(countThree, countMany) = boolFalse .
  eq gtExpr(exprError, Ex) = exprError .
  eq gtExpr(Ex, exprError) = exprError .
  eq geExpr(orderHigh, orderLow) = boolTrue .
  eq geExpr(orderHigh, orderEqual) = boolTrue .
  eq geExpr(orderEqual, orderLow) = boolTrue .
  eq geExpr(orderHigh, orderHigh) = boolTrue .
