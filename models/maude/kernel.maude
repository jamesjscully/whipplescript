  eq leExpr(countMany, countThree) = boolFalse .
  eq leExpr(exprError, Ex) = exprError .
  eq leExpr(Ex, exprError) = exprError .
  eq gtExpr(orderHigh, orderLow) = boolTrue .
  eq gtExpr(orderHigh, orderEqual) = boolTrue .
  eq gtExpr(orderEqual, orderLow) = boolTrue .
  eq gtExpr(orderHigh, orderHigh) = boolFalse .
  eq gtExpr(orderEqual, orderEqual) = boolFalse .
  eq gtExpr(orderLow, orderHigh) = boolFalse .
  eq gtExpr(countOne, countZero) = boolTrue .
  eq gtExpr(countTwo, countZero) = boolTrue .
