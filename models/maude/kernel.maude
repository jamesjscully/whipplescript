mod WHIPPLESCRIPT-KERNEL is
  sorts
    EffectId FactId RunId EventId RuleId GraphId
    WorkflowId InstanceId PatternId ApplicationId OutputId FailureId InstanceStatus
    ProgramVersion RevisionEpoch CancellationPolicy
    Predicate EffectStatus ProjectionStatus LeaseStatus GuardResult
    AssertionId AssertionResult AgentTarget Path Presence Value Domain
    Scalar QueryId QueryCardinality Expr ExprList Entry EntryList TerminalTag Cfg .

  --- Sample identifiers used by hand-written model tests.
  ops e1 e2 e3 : -> EffectId .
  ops claimEff tellEff askEff coerceEff recordEff : -> EffectId .
  ops issueFact workerFact claimFact turnFact : -> FactId .
  ops coerceOkFact coerceBadFact : -> FactId .
  ops run1 : -> RunId .
  ops event1 initEvt turnCompletedEvt coerceCompletedEvt coerceFailedEvt : -> EventId .
  ops ruleCommitEvt leaseExpiredEvt : -> EventId .
  ops workflowCompletedEvt workflowFailedEvt : -> EventId .
  op revisionActivatedEvt : -> EventId .
  ops ralphRule coerceRule : -> RuleId .
  ops guardedRule agentRule : -> RuleId .
  ops rootWorkflow reviewWorkflow : -> WorkflowId .
  ops version1 version2 : -> ProgramVersion .
  ops epoch0 epoch1 epoch2 : -> RevisionEpoch .
  ops keep cancelQueued requestRunning : -> CancellationPolicy .
  ops rootInstance childInstance : -> InstanceId .
  op reviewPattern : -> PatternId .
  op phaseReviewApplication : -> ApplicationId .
  ops reviewOutput reviewFailure : -> OutputId .
  op blockedFailure : -> FailureId .
  ops g1 g2 g3 : -> GraphId .
  ops assertion1 : -> AssertionId .
  ops codexAgent claudeAgent piAgent missingAgent : -> AgentTarget .
  ops assigneePath providerPath : -> Path .
  ops codexValue claudeValue invalidProviderValue : -> Value .
  ops scalar1 scalar2 : -> Scalar .
  ops query1 : -> QueryId .
  op providerDomain : -> Domain .

  --- Effect lifecycle states.
  ops
    queued
    blocked
    blockedByPolicy
    blockedByCapacity
    claimed
    running
    completed
    failed
    timedOut
    cancelled
    : -> EffectStatus .

  --- Projection and lease states.
  ops pending projected : -> ProjectionStatus .
  ops leaseActive leaseExpired : -> LeaseStatus .
  ops instRunning instCompleted instFailed instCancelled : -> InstanceStatus .

  --- Dependency predicates. These correspond to source-level
  --- `after effect succeeds|fails|completes` edges.
  ops succeeds fails completes : -> Predicate .

  --- Expression-kernel abstraction.
  ops gTrue gFalse gError : -> GuardResult .
  ops aPass aFail aError : -> AssertionResult .
  ops present missing : -> Presence .
  ops qZero qOne qTwo qThree qMany qError : -> QueryCardinality .
  ops boolTrue boolFalse exprError countZero countOne countTwo countThree countMany : -> Expr .
  ops orderLow orderEqual orderHigh arrayEmpty objectEmpty mapEmpty : -> Expr .
  ops terminalCompleted terminalFailed terminalTimedOut terminalCancelled : -> TerminalTag .

  --- Runtime configuration as a multiset.
  op none : -> Cfg .
  op __ : Cfg Cfg -> Cfg [assoc comm id: none] .

  --- Kernel projections.
  op effect : EffectId EffectStatus -> Cfg .
  op instance : InstanceId WorkflowId InstanceStatus -> Cfg .
  op activeRevision : InstanceId ProgramVersion RevisionEpoch -> Cfg .
  op nextEpoch : RevisionEpoch RevisionEpoch -> Cfg .
  op activateRevision : InstanceId ProgramVersion ProgramVersion RevisionEpoch RevisionEpoch CancellationPolicy -> Cfg .
  op revisionActivated : InstanceId ProgramVersion ProgramVersion RevisionEpoch CancellationPolicy -> Cfg .
  op revisionCancellationPolicy : InstanceId ProgramVersion RevisionEpoch CancellationPolicy -> Cfg .
  op dep : EffectId Predicate EffectId -> Cfg .
  op fact : FactId -> Cfg .
  op event : EventId -> Cfg .
  op run : RunId EffectId -> Cfg .
  op providerRun : EffectId -> Cfg .
  op effectVersion : EffectId ProgramVersion RevisionEpoch -> Cfg .
  op requestable : EffectId -> Cfg .
  op cancellationRequested : EffectId -> Cfg .
  op cancellationAcknowledged : EffectId -> Cfg .
  op providerEvidence : EffectId EffectStatus -> Cfg .
  op requiredArtifactCaptureFailure : EffectId -> Cfg .
  op correlates : EffectId FactId -> Cfg .
  op projection : EventId FactId ProjectionStatus -> Cfg .
  op completionProjection : EffectId EffectStatus FactId ProjectionStatus -> Cfg .
  op rule : RuleId FactId GraphId -> Cfg .
  op scopedRule : InstanceId RuleId FactId GraphId -> Cfg .
  op scopedRuleV : InstanceId ProgramVersion RevisionEpoch RuleId FactId GraphId -> Cfg .
  op guard : RuleId FactId GuardResult -> Cfg .
  op domainGuard : RuleId FactId Value Domain -> Cfg .
  op domainMember : Value Domain -> Cfg .
  op domainNonMember : Value Domain -> Cfg .
  op patternBranch : RuleId FactId Value Domain GraphId -> Cfg .
  op exhaustivePattern : RuleId FactId Value Domain -> Cfg .
  op optionalSomeBranch : RuleId FactId Path GraphId -> Cfg .
  op optionalNoneBranch : RuleId FactId Path GraphId -> Cfg .
  op boundPresent : Path -> Cfg .
  op ruleReady : RuleId FactId GraphId -> Cfg .
  op ruleFired : RuleId FactId GraphId -> Cfg .
  op scopedRuleFired : InstanceId RuleId FactId GraphId -> Cfg .
  op graph : GraphId EffectId -> Cfg .
  op graphV : GraphId ProgramVersion RevisionEpoch EffectId -> Cfg .
  op graph2 : GraphId EffectId Predicate EffectId -> Cfg .
  op graphAgent : GraphId EffectId AgentTarget -> Cfg .
  op graphReady : GraphId -> Cfg .
  op graphCommitted : GraphId -> Cfg .
  op assertion : AssertionId AssertionResult -> Cfg .
  op guardExpr : RuleId FactId Expr -> Cfg .
  op assertionExpr : AssertionId Expr -> Cfg .
  op scalar : Scalar -> Expr .
  op query : QueryId QueryCardinality -> Expr .
  op notExpr : Expr -> Expr .
  op andExpr : Expr Expr -> Expr .
  op orExpr : Expr Expr -> Expr .
  op eqExpr : Expr Expr -> Expr .
  op neExpr : Expr Expr -> Expr .
  op countExpr : Expr -> Expr .
  op existsExpr : Expr -> Expr .
  op emptyExpr : Expr -> Expr .
  op ltExpr : Expr Expr -> Expr .
  op leExpr : Expr Expr -> Expr .
  op gtExpr : Expr Expr -> Expr .
  op geExpr : Expr Expr -> Expr .
  op inExpr : Expr Expr -> Expr .
  op arrayHas : Expr -> Expr .
  op arrayMissing : Expr -> Expr .
  op exprNil : -> ExprList .
  op exprCons : Expr ExprList -> ExprList .
  op entry : Expr Expr -> Entry .
  op entryNil : -> EntryList .
  op entryCons : Entry EntryList -> EntryList .
  op arrayOf : ExprList -> Expr .
  op mapOf : EntryList -> Expr .
  op objectOf : EntryList -> Expr .
  op countList : ExprList -> Expr .
  op countEntries : EntryList -> Expr .
  op inList : Expr ExprList -> Expr .
  op inEntryKeys : Expr EntryList -> Expr .
  op indexEntries : Expr EntryList -> Expr .
  op mapHas : Expr Expr -> Expr .
  op mapMissing : Expr -> Expr .
  op objectHas : Expr Expr -> Expr .
  op objectMissing : Expr -> Expr .
  op indexExpr : Expr Expr -> Expr .
  op queryFilter : QueryId Expr QueryCardinality -> Expr .
  op terminalBranch : RuleId FactId TerminalTag TerminalTag GraphId -> Cfg .
  op terminalBranchGuard : RuleId FactId TerminalTag TerminalTag Expr GraphId -> Cfg .
  op exhaustiveTerminal : RuleId FactId TerminalTag TerminalTag -> Cfg .
  op evalGuard : Expr -> GuardResult .
  op evalAssertion : Expr -> AssertionResult .
  op declaredAgent : AgentTarget -> Cfg .
  op tellTarget : EffectId AgentTarget -> Cfg .
  op path : Path Presence -> Cfg .
  op readPath : Path -> Cfg .
  op readOk : Path -> Cfg .
  op diagnostic : RuleId -> Cfg .
  op assertionDiagnostic : AssertionId -> Cfg .
  op policyAllows : EffectId -> Cfg .
  op capacityAvailable : EffectId -> Cfg .
  op lease : EffectId LeaseStatus -> Cfg .
  op retryAllowed : EffectId -> Cfg .
  op retryUsed : EffectId -> Cfg .
  op patternApp : PatternId ApplicationId RuleId FactId GraphId -> Cfg .
  op patternElaborated : PatternId ApplicationId RuleId FactId GraphId -> Cfg .
  op ruleProvenance : RuleId PatternId ApplicationId -> Cfg .
  op workflowOutput : WorkflowId OutputId -> Cfg .
  op workflowFailure : WorkflowId FailureId -> Cfg .
  op completeWorkflow : InstanceId OutputId FactId -> Cfg .
  op failWorkflow : InstanceId FailureId FactId -> Cfg .
  op terminalPayload : InstanceId FactId -> Cfg .
  op invokeWorkflow : EffectId InstanceId WorkflowId InstanceId -> Cfg .
  op childOf : InstanceId EffectId -> Cfg .
  op invocationOutput : EffectId FactId -> Cfg .
  op invocationFailure : EffectId FactId -> Cfg .
  op invocationCancellation : EffectId -> Cfg .

  vars U D E : EffectId .
  vars F : FactId .
  vars I CI : InstanceId .
  vars W : WorkflowId .
  vars PV PV2 : ProgramVersion .
  vars Ep Ep2 : RevisionEpoch .
  vars CP : CancellationPolicy .
  vars Pat : PatternId .
  vars App : ApplicationId .
  vars O : OutputId .
  vars Fail : FailureId .
  vars Ev : EventId .
  vars R : RuleId .
  vars G : GraphId .
  vars A : AssertionId .
  vars T : AgentTarget .
  vars X : Path .
  vars V : Value .
  vars Dm : Domain .
  vars P : Predicate .
  vars S : EffectStatus .
  vars Sc : Scalar .
  vars Q : QueryId .
  var C : QueryCardinality .
  vars Ex Ex1 Ex2 Ex3 : Expr .
  var EL : ExprList .
  vars EN EN2 EN3 : Entry .
  var KL : EntryList .
  vars Tag Tag2 : TerminalTag .
  vars Rest Rest2 : Cfg .

  --- Deterministic expression-kernel subset used by generated per-program
  --- checks. Generated models lower guards/assertions into these terms instead
  --- of asserting symbolic true/false/error outcomes directly.
  eq countExpr(query(Q, qZero)) = countZero .
  eq countExpr(query(Q, qOne)) = countOne .
  eq countExpr(query(Q, qTwo)) = countTwo .
  eq countExpr(query(Q, qThree)) = countThree .
  eq countExpr(query(Q, qMany)) = countMany .
  eq countExpr(query(Q, qError)) = exprError .
  eq countExpr(queryFilter(Q, boolTrue, qZero)) = countZero .
  eq countExpr(queryFilter(Q, boolTrue, qOne)) = countOne .
  eq countExpr(queryFilter(Q, boolTrue, qTwo)) = countTwo .
  eq countExpr(queryFilter(Q, boolTrue, qThree)) = countThree .
  eq countExpr(queryFilter(Q, boolTrue, qMany)) = countMany .
  eq countExpr(queryFilter(Q, boolTrue, qError)) = exprError .
  eq countExpr(queryFilter(Q, boolFalse, C)) = countZero .
  eq countExpr(queryFilter(Q, exprError, C)) = exprError .
  eq countExpr(arrayEmpty) = countZero .
  eq countExpr(arrayHas(Ex)) = countOne .
  eq countExpr(arrayMissing(Ex)) = countZero .
  eq countExpr(arrayOf(EL)) = countList(EL) .
  eq countExpr(mapEmpty) = countZero .
  eq countExpr(mapHas(Ex1, Ex2)) = countOne .
  eq countExpr(mapMissing(Ex)) = countZero .
  eq countExpr(mapOf(KL)) = countEntries(KL) .
  eq countExpr(objectEmpty) = countZero .
  eq countExpr(objectHas(Ex1, Ex2)) = countOne .
  eq countExpr(objectMissing(Ex)) = countZero .
  eq countExpr(objectOf(KL)) = countEntries(KL) .
  eq countList(exprNil) = countZero .
  eq countList(exprCons(Ex, exprNil)) = countOne .
  eq countList(exprCons(Ex, exprCons(Ex1, exprNil))) = countTwo .
  eq countList(exprCons(Ex, exprCons(Ex1, exprCons(Ex2, exprNil)))) = countThree .
  eq countList(exprCons(Ex, exprCons(Ex1, exprCons(Ex2, exprCons(Ex3, EL))))) = countMany .
  eq countEntries(entryNil) = countZero .
  eq countEntries(entryCons(EN, entryNil)) = countOne .
  eq countEntries(entryCons(EN, entryCons(EN2, entryNil))) = countTwo .
  eq countEntries(entryCons(EN, entryCons(EN2, entryCons(EN3, entryNil)))) = countThree .
  eq countEntries(entryCons(EN, entryCons(EN2, entryCons(EN3, entryCons(EN, KL))))) = countMany .
  eq existsExpr(query(Q, qZero)) = boolFalse .
  eq existsExpr(query(Q, qOne)) = boolTrue .
  eq existsExpr(query(Q, qTwo)) = boolTrue .
  eq existsExpr(query(Q, qThree)) = boolTrue .
  eq existsExpr(query(Q, qMany)) = boolTrue .
  eq existsExpr(query(Q, qError)) = exprError .
  eq existsExpr(queryFilter(Q, boolTrue, qZero)) = boolFalse .
  eq existsExpr(queryFilter(Q, boolTrue, qOne)) = boolTrue .
  eq existsExpr(queryFilter(Q, boolTrue, qTwo)) = boolTrue .
  eq existsExpr(queryFilter(Q, boolTrue, qThree)) = boolTrue .
  eq existsExpr(queryFilter(Q, boolTrue, qMany)) = boolTrue .
  eq existsExpr(queryFilter(Q, boolTrue, qError)) = exprError .
  eq existsExpr(queryFilter(Q, boolFalse, C)) = boolFalse .
  eq existsExpr(queryFilter(Q, exprError, C)) = exprError .
  eq existsExpr(arrayEmpty) = boolFalse .
  eq existsExpr(arrayHas(Ex)) = boolTrue .
  eq existsExpr(arrayMissing(Ex)) = boolFalse .
  eq existsExpr(arrayOf(EL)) = notExpr(eqExpr(countList(EL), countZero)) .
  eq existsExpr(mapEmpty) = boolFalse .
  eq existsExpr(mapHas(Ex1, Ex2)) = boolTrue .
  eq existsExpr(mapMissing(Ex)) = boolFalse .
  eq existsExpr(mapOf(KL)) = notExpr(eqExpr(countEntries(KL), countZero)) .
  eq existsExpr(objectEmpty) = boolFalse .
  eq existsExpr(objectHas(Ex1, Ex2)) = boolTrue .
  eq existsExpr(objectMissing(Ex)) = boolFalse .
  eq existsExpr(objectOf(KL)) = notExpr(eqExpr(countEntries(KL), countZero)) .
  eq emptyExpr(query(Q, qZero)) = boolTrue .
  eq emptyExpr(query(Q, qOne)) = boolFalse .
  eq emptyExpr(query(Q, qMany)) = boolFalse .
  eq emptyExpr(query(Q, qError)) = exprError .
  eq emptyExpr(queryFilter(Q, boolTrue, qZero)) = boolTrue .
  eq emptyExpr(queryFilter(Q, boolTrue, qOne)) = boolFalse .
  eq emptyExpr(queryFilter(Q, boolTrue, qMany)) = boolFalse .
  eq emptyExpr(queryFilter(Q, boolTrue, qError)) = exprError .
  eq emptyExpr(queryFilter(Q, boolFalse, C)) = boolTrue .
  eq emptyExpr(queryFilter(Q, exprError, C)) = exprError .
  eq emptyExpr(arrayEmpty) = boolTrue .
  eq emptyExpr(arrayHas(Ex)) = boolFalse .
  eq emptyExpr(arrayMissing(Ex)) = boolTrue .
  eq emptyExpr(arrayOf(EL)) = eqExpr(countList(EL), countZero) .
  eq emptyExpr(mapEmpty) = boolTrue .
  eq emptyExpr(mapHas(Ex1, Ex2)) = boolFalse .
  eq emptyExpr(mapMissing(Ex)) = boolTrue .
  eq emptyExpr(mapOf(KL)) = eqExpr(countEntries(KL), countZero) .
  eq emptyExpr(objectEmpty) = boolTrue .
  eq emptyExpr(objectHas(Ex1, Ex2)) = boolFalse .
  eq emptyExpr(objectMissing(Ex)) = boolTrue .
  eq emptyExpr(objectOf(KL)) = eqExpr(countEntries(KL), countZero) .
  eq notExpr(boolTrue) = boolFalse .
  eq notExpr(boolFalse) = boolTrue .
  eq notExpr(exprError) = exprError .
  eq andExpr(boolFalse, Ex) = boolFalse .
  eq andExpr(boolTrue, Ex) = Ex .
  eq andExpr(exprError, Ex) = exprError .
  eq orExpr(boolTrue, Ex) = boolTrue .
  eq orExpr(boolFalse, Ex) = Ex .
  eq orExpr(exprError, Ex) = exprError .
  eq eqExpr(scalar(Sc), scalar(Sc)) = boolTrue .
  eq neExpr(scalar(Sc), scalar(Sc)) = boolFalse .
  eq eqExpr(boolTrue, boolTrue) = boolTrue .
  eq eqExpr(boolTrue, boolFalse) = boolFalse .
  eq eqExpr(boolFalse, boolTrue) = boolFalse .
  eq eqExpr(boolFalse, boolFalse) = boolTrue .
  eq neExpr(boolTrue, boolTrue) = boolFalse .
  eq neExpr(boolTrue, boolFalse) = boolTrue .
  eq neExpr(boolFalse, boolTrue) = boolTrue .
  eq neExpr(boolFalse, boolFalse) = boolFalse .
  eq eqExpr(countZero, countZero) = boolTrue .
  eq eqExpr(countZero, countOne) = boolFalse .
  eq eqExpr(countZero, countTwo) = boolFalse .
  eq eqExpr(countZero, countThree) = boolFalse .
  eq eqExpr(countZero, countMany) = boolFalse .
  eq eqExpr(countOne, countZero) = boolFalse .
  eq eqExpr(countOne, countOne) = boolTrue .
  eq eqExpr(countOne, countTwo) = boolFalse .
  eq eqExpr(countOne, countThree) = boolFalse .
  eq eqExpr(countTwo, countZero) = boolFalse .
  eq eqExpr(countTwo, countOne) = boolFalse .
  eq eqExpr(countTwo, countTwo) = boolTrue .
  eq eqExpr(countTwo, countThree) = boolFalse .
  eq eqExpr(countTwo, countMany) = boolFalse .
  eq eqExpr(countThree, countZero) = boolFalse .
  eq eqExpr(countThree, countOne) = boolFalse .
  eq eqExpr(countThree, countTwo) = boolFalse .
  eq eqExpr(countThree, countThree) = boolTrue .
  eq eqExpr(countThree, countMany) = boolFalse .
  eq eqExpr(countMany, countMany) = boolTrue .
  eq eqExpr(countOne, countMany) = boolFalse .
  eq eqExpr(countMany, countOne) = boolFalse .
  eq eqExpr(countMany, countZero) = boolFalse .
  eq eqExpr(countMany, countTwo) = boolFalse .
  eq eqExpr(countMany, countThree) = boolFalse .
  eq neExpr(countZero, countZero) = boolFalse .
  eq neExpr(countZero, countOne) = boolTrue .
  eq neExpr(countZero, countTwo) = boolTrue .
  eq neExpr(countZero, countThree) = boolTrue .
  eq neExpr(countZero, countMany) = boolTrue .
  eq neExpr(countOne, countZero) = boolTrue .
  eq neExpr(countOne, countOne) = boolFalse .
  eq neExpr(countOne, countTwo) = boolTrue .
  eq neExpr(countOne, countThree) = boolTrue .
  eq neExpr(countTwo, countZero) = boolTrue .
  eq neExpr(countTwo, countOne) = boolTrue .
  eq neExpr(countTwo, countTwo) = boolFalse .
  eq neExpr(countTwo, countThree) = boolTrue .
  eq neExpr(countTwo, countMany) = boolTrue .
  eq neExpr(countThree, countZero) = boolTrue .
  eq neExpr(countThree, countOne) = boolTrue .
  eq neExpr(countThree, countTwo) = boolTrue .
  eq neExpr(countThree, countThree) = boolFalse .
  eq neExpr(countThree, countMany) = boolTrue .
  eq neExpr(countMany, countMany) = boolFalse .
  eq neExpr(countOne, countMany) = boolTrue .
  eq neExpr(countMany, countOne) = boolTrue .
  eq neExpr(countMany, countZero) = boolTrue .
  eq neExpr(countMany, countTwo) = boolTrue .
  eq neExpr(countMany, countThree) = boolTrue .
  eq ltExpr(orderLow, orderHigh) = boolTrue .
  eq ltExpr(orderLow, orderEqual) = boolTrue .
  eq ltExpr(orderEqual, orderHigh) = boolTrue .
  eq ltExpr(orderLow, orderLow) = boolFalse .
  eq ltExpr(orderEqual, orderEqual) = boolFalse .
  eq ltExpr(orderHigh, orderLow) = boolFalse .
  eq ltExpr(countZero, countOne) = boolTrue .
  eq ltExpr(countZero, countTwo) = boolTrue .
  eq ltExpr(countZero, countThree) = boolTrue .
  eq ltExpr(countZero, countMany) = boolTrue .
  eq ltExpr(countOne, countMany) = boolTrue .
  eq ltExpr(countOne, countTwo) = boolTrue .
  eq ltExpr(countOne, countThree) = boolTrue .
  eq ltExpr(countTwo, countThree) = boolTrue .
  eq ltExpr(countTwo, countMany) = boolTrue .
  eq ltExpr(countThree, countMany) = boolTrue .
  eq ltExpr(countZero, countZero) = boolFalse .
  eq ltExpr(countOne, countOne) = boolFalse .
  eq ltExpr(countTwo, countTwo) = boolFalse .
  eq ltExpr(countThree, countThree) = boolFalse .
  eq ltExpr(countMany, countMany) = boolFalse .
  eq ltExpr(countOne, countZero) = boolFalse .
  eq ltExpr(countTwo, countZero) = boolFalse .
  eq ltExpr(countTwo, countOne) = boolFalse .
  eq ltExpr(countThree, countZero) = boolFalse .
  eq ltExpr(countThree, countOne) = boolFalse .
  eq ltExpr(countThree, countTwo) = boolFalse .
  eq ltExpr(countMany, countZero) = boolFalse .
  eq ltExpr(countMany, countOne) = boolFalse .
  eq ltExpr(countMany, countTwo) = boolFalse .
  eq ltExpr(countMany, countThree) = boolFalse .
  eq ltExpr(exprError, Ex) = exprError .
  eq ltExpr(Ex, exprError) = exprError .
  eq leExpr(orderLow, orderHigh) = boolTrue .
  eq leExpr(orderLow, orderEqual) = boolTrue .
  eq leExpr(orderEqual, orderHigh) = boolTrue .
  eq leExpr(orderLow, orderLow) = boolTrue .
  eq leExpr(orderEqual, orderEqual) = boolTrue .
  eq leExpr(orderHigh, orderLow) = boolFalse .
  eq leExpr(countZero, countZero) = boolTrue .
  eq leExpr(countZero, countOne) = boolTrue .
  eq leExpr(countZero, countTwo) = boolTrue .
  eq leExpr(countZero, countThree) = boolTrue .
  eq leExpr(countZero, countMany) = boolTrue .
  eq leExpr(countOne, countOne) = boolTrue .
  eq leExpr(countOne, countTwo) = boolTrue .
  eq leExpr(countOne, countThree) = boolTrue .
  eq leExpr(countOne, countMany) = boolTrue .
  eq leExpr(countTwo, countTwo) = boolTrue .
  eq leExpr(countTwo, countThree) = boolTrue .
  eq leExpr(countTwo, countMany) = boolTrue .
  eq leExpr(countThree, countThree) = boolTrue .
  eq leExpr(countThree, countMany) = boolTrue .
  eq leExpr(countMany, countMany) = boolTrue .
  eq leExpr(countOne, countZero) = boolFalse .
  eq leExpr(countTwo, countZero) = boolFalse .
  eq leExpr(countTwo, countOne) = boolFalse .
  eq leExpr(countThree, countZero) = boolFalse .
  eq leExpr(countThree, countOne) = boolFalse .
  eq leExpr(countThree, countTwo) = boolFalse .
  eq leExpr(countMany, countZero) = boolFalse .
