  eq gtExpr(countThree, countZero) = boolTrue .
  eq gtExpr(countThree, countOne) = boolTrue .
  eq gtExpr(countThree, countTwo) = boolTrue .
  eq gtExpr(countMany, countZero) = boolTrue .
  eq gtExpr(countMany, countOne) = boolTrue .
  eq gtExpr(countMany, countTwo) = boolTrue .
  eq gtExpr(countMany, countThree) = boolTrue .
  eq gtExpr(countZero, countZero) = boolFalse .
  eq gtExpr(countOne, countOne) = boolFalse .
  eq gtExpr(countTwo, countTwo) = boolFalse .
  eq gtExpr(countThree, countThree) = boolFalse .
